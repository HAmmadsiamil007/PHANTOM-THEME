<button
  class="sticky-offers-button"
  data-open-drawer="OffersDrawer"
  aria-label="View offers"
  type="button"
>
  <span class="sticky-offers-button__tooltip" data-offers-drawer-tooltip>
    View our latest offers!
  </span>
  {%- render 'ui-icon', name: 'gift', library: 'ph-icon' -%}
</button>

{% stylesheet %}
  .sticky-offers-button {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 998;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    background: var(--colorBtnPrimary, #000);
    color: var(--colorBtnPrimaryText, #fff);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.2);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    padding: 0;
  }

  .sticky-offers-button:hover {
    transform: scale(1.05);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
  }

  .sticky-offers-button svg {
    width: 24px;
    height: 24px;
  }

  .sticky-offers-button__tooltip {
    position: absolute;
    bottom: calc(100% + 8px);
    right: 0;
    background: var(--colorTextBody, #333);
    color: var(--colorBodyBg, #fff);
    padding: 8px 12px;
    border-radius: 6px;
    font-size: 13px;
    line-height: 1.3;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .sticky-offers-button__tooltip.visible {
    opacity: 1;
  }
{% endstylesheet %}
