{%- if product != blank -%}
  {%- liquid
    assign on_sale = false
    if product.compare_at_price > product.price
      assign on_sale = true
    endif
    assign featured_image = product.featured_media.preview_image
  -%}

  <div class="quiz-card" data-quiz-product-card data-product-handle="{{ product.handle }}">
    <div class="quiz-card__image">
      {%- if featured_image != blank -%}
        <a href="{{ product.url }}">
          {{ featured_image | image_url: width: 400 | image_tag: loading: 'lazy', class: 'quiz-card__img' }}
        </a>
      {%- else -%}
        <div class="quiz-card__placeholder">{{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
      {%- endif -%}
    </div>

    <div class="quiz-card__info">
      <a href="{{ product.url }}" class="quiz-card__title">{{ product.title }}</a>

      <div class="quiz-card__price">
        {%- if on_sale -%}
          <span class="quiz-card__price--sale">{{ product.price | money }}</span>
          <span class="quiz-card__price--compare"><s>{{ product.compare_at_price | money }}</s></span>
        {%- else -%}
          {%- if product.price_varies -%}
            {{ product.price_min | money }} - {{ product.price_max | money }}
          {%- else -%}
            {{ product.price | money }}
          {%- endif -%}
        {%- endif -%}
      </div>

      {%- assign variant = product.selected_or_first_available_variant -%}
      {%- if variant.available -%}
        <form method="post" action="/cart/add" class="quiz-card__form">
          <input type="hidden" name="id" value="{{ variant.id }}">
          <input type="hidden" name="quantity" value="1">
          <button type="submit" class="btn btn--small btn--full quiz-card__add-btn" data-quiz-add-to-cart>
            <span>{{ 'products.product.add_to_cart' | t }}</span>
          </button>
        </form>
      {%- else -%}
        <button class="btn btn--small btn--full btn--disabled" disabled>
          {{ 'products.product.sold_out' | t }}
        </button>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}
