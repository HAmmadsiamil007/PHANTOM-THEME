{%- liquid
  assign text_color_alpha = section.settings.text_color | color_extract: 'alpha'
  assign background_color_alpha = section.settings.background_color | color_extract: 'alpha'
  assign background_brightness = section.settings.background_color | color_brightness
  if background_brightness < 125
    assign accent_color = '#FFF'
  else
    assign accent_color = '#000'
  endif
-%}

{% render 'section-tokens', settings: section.settings, section_id: section.id %}
{% render 'section-visibility', settings: section.settings, section_id: section.id %}

{%- style -%}
  #impulse-countdown--{{ section.id }} {
    padding-block: var(--padding-section);
  }

  #impulse-countdown--{{ section.id }} .impulse-countdown__wrapper {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    {% if section.settings.full_width == false %}
      border-radius: var(--style-border-radius);
    {% endif %}
  }

  #impulse-countdown--{{ section.id }} .impulse-countdown__background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  #impulse-countdown--{{ section.id }} .impulse-countdown__background img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #impulse-countdown--{{ section.id }} .impulse-countdown__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  #impulse-countdown--{{ section.id }} .impulse-countdown__content {
    position: relative;
    z-index: 2;
    width: 100%;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--gap-lg);
    padding: var(--padding-lg) var(--padding-md);
    min-height: 200px;
    text-align: center;
  }

  #impulse-countdown--{{ section.id }} .impulse-countdown__heading {
    margin-block: 0 var(--margin-xs);
  }

  #impulse-countdown--{{ section.id }} .impulse-countdown__richtext {
    font-size: 0.9375rem;
    line-height: 1.6;
    opacity: 0.85;
  }

  #impulse-countdown--{{ section.id }} .impulse-countdown__timer {
    display: flex;
    gap: var(--gap-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  #impulse-countdown--{{ section.id }} .impulse-countdown__timer-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 60px;
  }

  #impulse-countdown--{{ section.id }} .impulse-countdown__timer-value {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
    margin-block-end: 0.25rem;
  }

  #impulse-countdown--{{ section.id }} .impulse-countdown__timer-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.7;
  }

  #impulse-countdown--{{ section.id }} .impulse-countdown__message {
    width: 100%;
    font-size: 0.9375rem;
    line-height: 1.5;
    margin-block-start: var(--margin-sm);
  }

  #impulse-countdown--{{ section.id }} .impulse-countdown__button {
    display: inline-block;
    padding: 0.75rem 2rem;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: var(--style-border-radius);
    transition: opacity 0.2s ease;
  }

  #impulse-countdown--{{ section.id }} .impulse-countdown__button:hover {
    opacity: 0.85;
  }

  #impulse-countdown--{{ section.id }} .impulse-countdown__button--solid {
    color: var(--color-foreground);
    background: rgb(var(--color-foreground-rgb) / 0.1);
  }

  #impulse-countdown--{{ section.id }} .impulse-countdown__button--secondary {
    color: var(--color-foreground);
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.2);
  }

  @media screen and (max-width: 749px) {
    #impulse-countdown--{{ section.id }} .impulse-countdown__content {
      flex-direction: column;
      padding: var(--padding-md);
    }

    #impulse-countdown--{{ section.id }} .impulse-countdown__timer-value {
      font-size: 1.5rem;
    }

    #impulse-countdown--{{ section.id }} .impulse-countdown__background--desktop {
      display: none;
    }
  }

  @media screen and (min-width: 750px) {
    #impulse-countdown--{{ section.id }} .impulse-countdown__background--mobile {
      display: none;
    }
  }
{%- endstyle -%}

<div
  id="impulse-countdown--{{ section.id }}"
  class="section section--{% if section.settings.full_width %}full-width{% else %}page-width{% endif %}"
  style="
    --countdown-text-color: {{ section.settings.text_color }};
    --countdown-bg-color: {{ section.settings.background_color }};
    --accent-color: {{ accent_color }};
  "
>
  <div class="impulse-countdown__wrapper" style="background-color: {{ section.settings.background_color }};">
    {%- if section.settings.background_image != blank -%}
      <div class="impulse-countdown__background impulse-countdown__background--desktop">
        {% render 'image', image: section.settings.background_image, width: 2400, class: 'impulse-countdown__bg-img', alt_text_fallback: '' %}
      </div>
      {%- if section.settings.overlay_opacity > 0 -%}
        {%- assign overlay_alpha = section.settings.overlay_opacity | divided_by: 100.0 -%}
        <div class="impulse-countdown__overlay" style="background-color: {{ section.settings.overlay_color | color_modify: 'alpha', overlay_alpha }};"></div>
      {%- endif -%}
    {%- endif -%}

    {%- if section.settings.mobile_image != blank -%}
      <div class="impulse-countdown__background impulse-countdown__background--mobile">
        {% render 'image', image: section.settings.mobile_image, width: 600, class: 'impulse-countdown__bg-img', alt_text_fallback: '' %}
      </div>
      {%- if section.settings.overlay_opacity > 0 -%}
        {%- assign overlay_alpha = section.settings.overlay_opacity | divided_by: 100.0 -%}
        <div class="impulse-countdown__overlay" style="background-color: {{ section.settings.overlay_color | color_modify: 'alpha', overlay_alpha }};"></div>
      {%- endif -%}
    {%- endif -%}

    <div class="impulse-countdown__content" style="color: {{ section.settings.text_color }};">
      {%- for block in section.blocks -%}
        {%- if block.type == 'timer' -%}
          <div class="impulse-countdown__block" {{ block.shopify_attributes }}>
            <countdown-timer
              data-year="{{ block.settings.year }}"
              data-month="{{ block.settings.month }}"
              data-day="{{ block.settings.day }}"
              data-hour="{{ block.settings.hour }}"
              data-minute="{{ block.settings.minute }}"
              data-hide-timer="{{ block.settings.hide_timer }}"
              data-complete-message="{{ block.settings.text | escape }}"
            >
              <div class="impulse-countdown__timer" data-timer-display>
                <div class="impulse-countdown__timer-block">
                  <span class="impulse-countdown__timer-value" data-days-placeholder>00</span>
                  <span class="impulse-countdown__timer-label">Days</span>
                </div>
                <div class="impulse-countdown__timer-block">
                  <span class="impulse-countdown__timer-value" data-hours-placeholder>00</span>
                  <span class="impulse-countdown__timer-label">Hours</span>
                </div>
                <div class="impulse-countdown__timer-block">
                  <span class="impulse-countdown__timer-value" data-minutes-placeholder>00</span>
                  <span class="impulse-countdown__timer-label">Minutes</span>
                </div>
                <div class="impulse-countdown__timer-block">
                  <span class="impulse-countdown__timer-value" data-seconds-placeholder>00</span>
                  <span class="impulse-countdown__timer-label">Seconds</span>
                </div>
              </div>
              {%- if block.settings.text != blank -%}
                <div class="impulse-countdown__message" data-message-placeholder>{{ block.settings.text }}</div>
              {%- endif -%}
            </countdown-timer>
          </div>
        {%- endif -%}

        {%- if block.type == 'content' -%}
          <div class="impulse-countdown__block" {{ block.shopify_attributes }}>
            <div class="impulse-countdown__text-wrapper" style="text-align: {{ block.settings.content_alignment }};">
              {%- if block.settings.heading != blank -%}
                <h2 class="impulse-countdown__heading {{ block.settings.heading_size }}">{{ block.settings.heading }}</h2>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="impulse-countdown__richtext">{{ block.settings.text }}</div>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        {%- if block.type == 'button' and block.settings.button != blank -%}
          <div class="impulse-countdown__block" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.button_link }}" class="impulse-countdown__button impulse-countdown__button--{{ block.settings.button_style }}">
              {{ block.settings.button }}
            </a>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{%- unless request.design_mode -%}
  <script type="module">
    class CountdownTimer extends HTMLElement {
      constructor() {
        super();
        this._timerId = null;
      }

      connectedCallback() {
        if (this.dataset.hideTimer === 'true') {
          this.querySelector('[data-timer-display]')?.remove();
        }
        this._start();
      }

      disconnectedCallback() {
        if (this._timerId) {
          clearInterval(this._timerId);
        }
      }

      _start() {
        const target = new Date(
          parseInt(this.dataset.year),
          parseInt(this.dataset.month) - 1,
          parseInt(this.dataset.day),
          parseInt(this.dataset.hour),
          parseInt(this.dataset.minute)
        ).getTime();

        const update = () => {
          const now = Date.now();
          const diff = Math.max(0, target - now);

          if (diff <= 0) {
            clearInterval(this._timerId);
            const message = this.dataset.completeMessage;
            if (message) {
              this.innerHTML = `<div class="impulse-countdown__message">${message}</div>`;
            }
            return;
          }

          const days = Math.floor(diff / 86400000);
          const hours = Math.floor((diff % 86400000) / 3600000);
          const minutes = Math.floor((diff % 3600000) / 60000);
          const seconds = Math.floor((diff % 60000) / 1000);

          this.querySelector('[data-days-placeholder]').textContent = String(days).padStart(2, '0');
          this.querySelector('[data-hours-placeholder]').textContent = String(hours).padStart(2, '0');
          this.querySelector('[data-minutes-placeholder]').textContent = String(minutes).padStart(2, '0');
          this.querySelector('[data-seconds-placeholder]').textContent = String(seconds).padStart(2, '0');
        };

        update();
        this._timerId = setInterval(update, 1000);
      }
    }

    if (!customElements.get('countdown-timer')) {
      customElements.define('countdown-timer', CountdownTimer);
    }
  </script>
{%- endunless -%}

