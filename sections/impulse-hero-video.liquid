{%- liquid
  assign section_id = section.id
  assign video_url = section.settings.video_url
  assign title = section.settings.title
  assign subheading = section.settings.subheading
  assign link_text = section.settings.link_text
  assign link_url = section.settings.link
  assign overlay_opacity = section.settings.overlay_opacity
  assign color_accent = section.settings.color_accent
  assign button_alpha = color_accent | color_extract: 'alpha'

  if link_url == blank and video_url != blank
    assign link_url = video_url
  endif

  assign video_id = false
  assign video_type = false

  if video_url contains 'youtube.com/watch'
    assign video_parts = video_url | split: 'v='
    assign video_id = video_parts[1] | split: '&' | first
    assign video_type = 'youtube'
  elsif video_url contains 'youtu.be/'
    assign video_parts = video_url | split: '.be/'
    assign video_id = video_parts[1] | split: '&' | first
    assign video_type = 'youtube'
  elsif video_url contains 'vimeo.com'
    assign video_parts = video_url | split: '.com/'
    assign video_id = video_parts[1] | split: '/' | first
    assign video_type = 'vimeo'
  elsif video_url contains '.mp4' or video_url contains '.MP4'
    assign video_type = 'mp4'
  endif
-%}

{% render 'section-tokens', settings: section.settings, section_id: section_id %}
{% render 'section-visibility', settings: section.settings, section_id: section_id %}

{%- style -%}
  #impulse-hero-video--{{ section_id }} {
    position: relative;
    overflow: hidden;
    height: {{ section.settings.section_height }};
    {% if section.settings.section_height == '100vh' %}
      min-height: 100svh;
    {% endif %}
  }

  #impulse-hero-video--{{ section_id }} .hero-video__media {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
    background: #000;
  }

  #impulse-hero-video--{{ section_id }} .hero-video__media video,
  #impulse-hero-video--{{ section_id }} .hero-video__media iframe {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: 0;
  }

  #impulse-hero-video--{{ section_id }} .hero-video__text-wrap {
    position: relative;
    z-index: 3;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: {{ section.settings.text_align | split: ' ' | first | replace: 'vertical-center', 'center' | replace: 'vertical-bottom', 'flex-end' }};
    justify-content: {{ section.settings.text_align | split: ' ' | last | replace: 'horizontal-left', 'flex-start' | replace: 'horizontal-center', 'center' | replace: 'horizontal-right', 'flex-end' }};
  }

  @media screen and (max-width: 768px) {
    #impulse-hero-video--{{ section_id }} .hero-video__text-wrap {
      align-items: {{ section.settings.text_align_mobile | split: ' ' | first | replace: 'vertical-center', 'center' | replace: 'vertical-bottom', 'flex-end' | default: 'center' }};
      justify-content: {{ section.settings.text_align_mobile | split: ' ' | last | replace: 'horizontal-left', 'flex-start' | replace: 'horizontal-center', 'center' | replace: 'horizontal-right', 'flex-end' | default: 'center' }};
    }
  }

  #impulse-hero-video--{{ section_id }} .hero-video__text-shadow {
    max-width: 600px;
    padding: 32px;
  }

  #impulse-hero-video--{{ section_id }} .hero-video__title {
    margin: 0 0 12px;
    font-size: {{ section.settings.title_size | times: 0.5 }}px;
    font-weight: 700;
    line-height: 1.1;
    color: #fff;
  }

  @media screen and (min-width: 769px) {
    #impulse-hero-video--{{ section_id }} .hero-video__title {
      font-size: {{ section.settings.title_size }}px;
    }
  }

  #impulse-hero-video--{{ section_id }} .hero-video__subtitle {
    margin: 0 0 20px;
    font-size: 1.1em;
    line-height: 1.5;
    color: rgba(255,255,255,0.85);
  }

  #impulse-hero-video--{{ section_id }} .hero-video__link .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    font-size: 0.95em;
    font-weight: 600;
    text-decoration: none;
    border: none;
    border-radius: 2px;
    cursor: pointer;
    transition: opacity 0.2s ease;
    {% if button_alpha > 0 %}
      background: {{ color_accent }} !important;
      border-color: {{ color_accent }} !important;
      {% assign accent_brightness = color_accent | color_extract: 'lightness' %}
      {% if accent_brightness > 50 %}
        color: #000 !important;
      {% else %}
        color: #fff !important;
      {% endif %}
    {% else %}
      background: #fff;
      color: #000;
    {% endif %}
  }

  #impulse-hero-video--{{ section_id }} .hero-video__link .btn:hover {
    opacity: 0.85;
  }

  #impulse-hero-video--{{ section_id }} .hero-video__link .btn svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  /* Overlay */
  #impulse-hero-video--{{ section_id }} .hero-video__text-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: #000;
    opacity: {{ overlay_opacity | divided_by: 100.0 }};
  }

  /* Mobile height */
  @media screen and (max-width: 768px) {
    #impulse-hero-video--{{ section_id }} {
      height: {{ section.settings.mobile_height }};
      {% if section.settings.mobile_height == '100vh' %}
        min-height: 100svh;
      {% endif %}
    }
  }
{%- endstyle -%}

<div
  id="impulse-hero-video--{{ section_id }}"
  class="impulse-hero-video"
  data-section-type="hero-video"
  data-section-id="{{ section_id }}"
>
  <div class="hero-video__media">
    {%- if video_type == 'youtube' -%}
      <iframe
        src="//www.youtube.com/embed/{{ video_id }}?rel=0&showinfo=0&vq=720&autoplay=1&loop=1&mute=1&playlist={{ video_id }}&controls=0"
        allow="autoplay; encrypted-media"
        allowfullscreen
        loading="lazy"
        tabindex="-1"
      ></iframe>
    {%- elsif video_type == 'vimeo' -%}
      <iframe
        src="//player.vimeo.com/video/{{ video_id }}?autoplay=1&loop=1&muted=1&byline=0&portrait=0&badge=0&background=1"
        allow="autoplay; encrypted-media"
        allowfullscreen
        loading="lazy"
        tabindex="-1"
      ></iframe>
    {%- elsif video_type == 'mp4' -%}
      <video
        src="{{ video_url }}"
        autoplay
        loop
        muted
        playsinline
        preload="auto"
      ></video>
    {%- else -%}
      <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#666;background:#222;font-size:0.9em;">
        Select a video in the theme editor
      </div>
    {%- endif -%}
  </div>

  <div class="hero-video__text-wrap">
    <div class="page-width">
      <div class="hero-video__text-shadow">
        {%- unless title == blank -%}
          <h2 class="hero-video__title">{{ title | newline_to_br }}</h2>
        {%- endunless -%}

        {%- unless subheading == blank -%}
          <div class="hero-video__subtitle">{{ subheading | escape }}</div>
        {%- endunless -%}

        {%- if link_text != blank -%}
          <div class="hero-video__link">
            <a href="{{ link_url }}" class="btn">
              <svg aria-hidden="true" viewBox="18.24 17.35 24.52 28.3" width="18" height="18"><path fill="currentColor" d="M22.1 19.151v25.5l20.4-13.489-20.4-12.011z"/></svg>
              {{ link_text }}
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero video",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Heading",
      "default": "Made for the moments that matter"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Heading size",
      "default": 60,
      "min": 24,
      "max": 120,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Every detail tells a story."
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Button label",
      "default": "Watch now"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Button link",
      "info": "Leave blank to link to the video URL."
    },
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL",
      "default": "https://www.youtube.com/watch?v=_9VUPq3SxOc",
      "info": "Accepts YouTube, Vimeo, or direct .mp4 URLs."
    },
    {
      "type": "header",
      "content": "Design"
    },
    {
      "type": "color",
      "id": "color_accent",
      "label": "Button accent color",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay darkness",
      "default": 30,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment — desktop",
      "default": "vertical-center horizontal-center",
      "options": [
        { "value": "vertical-center horizontal-left", "label": "Center left" },
        { "value": "vertical-center horizontal-center", "label": "Center" },
        { "value": "vertical-center horizontal-right", "label": "Center right" },
        { "value": "vertical-bottom horizontal-left", "label": "Bottom left" },
        { "value": "vertical-bottom horizontal-center", "label": "Bottom center" },
        { "value": "vertical-bottom horizontal-right", "label": "Bottom right" }
      ]
    },
    {
      "type": "select",
      "id": "text_align_mobile",
      "label": "Text alignment — mobile",
      "default": "vertical-center horizontal-center",
      "options": [
        { "value": "vertical-center horizontal-left", "label": "Center left" },
        { "value": "vertical-center horizontal-center", "label": "Center" },
        { "value": "vertical-center horizontal-right", "label": "Center right" },
        { "value": "vertical-bottom horizontal-left", "label": "Bottom left" },
        { "value": "vertical-bottom horizontal-center", "label": "Bottom center" },
        { "value": "vertical-bottom horizontal-right", "label": "Bottom right" }
      ]
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Section height — desktop",
      "default": "650px",
      "options": [
        { "value": "450px", "label": "450px" },
        { "value": "550px", "label": "550px" },
        { "value": "650px", "label": "650px" },
        { "value": "750px", "label": "750px" },
        { "value": "100vh", "label": "Full screen" }
      ]
    },
    {
      "type": "select",
      "id": "mobile_height",
      "label": "Section height — mobile",
      "default": "auto",
      "options": [
        { "value": "auto", "label": "Auto (natural)" },
        { "value": "250px", "label": "250px" },
        { "value": "300px", "label": "300px" },
        { "value": "400px", "label": "400px" },
        { "value": "500px", "label": "500px" },
        { "value": "100vh", "label": "Full screen" }
      ]
    },
    {
      "type": "header",
      "content": "⚡ Design Tokens",
      "info": "Override global design tokens for this section only. Leave blank to use global defaults."
    },
    {
      "type": "color",
      "id": "token_primary_color",
      "label": "Primary accent",
      "placeholder": "Global default"
    },
    {
      "type": "color",
      "id": "token_text_color",
      "label": "Text color",
      "placeholder": "Global default"
    },
    {
      "type": "color",
      "id": "token_bg_color",
      "label": "Background",
      "placeholder": "Global default"
    },
    {
      "type": "color",
      "id": "token_accent_color",
      "label": "Accent/highlight",
      "placeholder": "Global default"
    },
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Hide on mobile",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_on_desktop",
      "label": "Hide on desktop",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Hero video",
      "category": "Banners"
    }
  ],
  "disabled_on": {
    "groups": ["footer", "header", "custom.popups"]
  }
}
{% endschema %}
