<style>
  {%- if settings.color_announcement == settings.color_body_bg -%}
    .announcement-bar {
      border-bottom: 1px solid;
    }
  {%- endif -%}
</style>

{%- render 'announcement-bar', section: section -%}

{% schema %}
{
  "name": "t:sections.header.settings.header_announcement_bar",
  "class": "announcement-bar-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "announcement_compact",
      "label": "t:sections.header.settings.announcement_compact.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show navigation arrows",
      "default": true
    },
    {
      "type": "select",
      "id": "arrow_style",
      "label": "Arrow style",
      "default": "small",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ]
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow color",
      "default": "rgba(0,0,0,0.5)"
    },
    {
      "type": "checkbox",
      "id": "show_close",
      "label": "Show close button",
      "default": false
    },
    {
      "type": "select",
      "id": "close_position",
      "label": "Close button position",
      "default": "right",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "select",
      "id": "height",
      "label": "Height",
      "default": "auto",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ]
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "position",
      "label": "Position",
      "default": "static",
      "options": [
        { "value": "static", "label": "Static" },
        { "value": "sticky_top", "label": "Sticky top" },
        { "value": "fixed_top", "label": "Fixed top" }
      ]
    },
    {
      "type": "range",
      "id": "z_index",
      "label": "Z-index",
      "default": 10,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "default": 14,
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "default": "400",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi bold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "default": 0,
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text transform",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "lowercase", "label": "Lowercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ]
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#f7f7f7"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1c1d1d"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#1c1d1d"
    },
    {
      "type": "range",
      "id": "bg_opacity",
      "label": "Background opacity",
      "default": 100,
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "default": 10,
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "default": 10,
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Border"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border width",
      "default": 0,
      "min": 0,
      "max": 5,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e8e8e8"
    },
    {
      "type": "select",
      "id": "border_style",
      "label": "Border style",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "dashed", "label": "Dashed" },
        { "value": "dotted", "label": "Dotted" }
      ]
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "default": 0,
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Shadow"
    },
    {
      "type": "select",
      "id": "shadow",
      "label": "Shadow",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ]
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "select",
      "id": "animation_style",
      "label": "Animation style",
      "default": "fade",
      "options": [
        { "value": "fade", "label": "Fade" },
        { "value": "slide", "label": "Slide" },
        { "value": "marquee", "label": "Marquee" },
        { "value": "none", "label": "None" }
      ]
    },
    {
      "type": "range",
      "id": "transition_duration",
      "label": "Transition duration",
      "default": 500,
      "min": 100,
      "max": 2000,
      "step": 100,
      "unit": "ms"
    },
    {
      "type": "select",
      "id": "auto_play_speed",
      "label": "Auto-play speed",
      "default": "5000",
      "options": [
        { "value": "3000", "label": "3s" },
        { "value": "4000", "label": "4s" },
        { "value": "5000", "label": "5s" },
        { "value": "6000", "label": "6s" },
        { "value": "7000", "label": "7s" },
        { "value": "8000", "label": "8s" },
        { "value": "10000", "label": "10s" }
      ]
    },
    {
      "type": "header",
      "content": "Responsive"
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on mobile",
      "default": true
    },
    {
      "type": "range",
      "id": "mobile_font_size",
      "label": "Mobile font size",
      "default": 12,
      "min": 8,
      "max": 20,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Accessibility"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "ARIA label",
      "default": "Announcements",
      "info": "Used for screen readers to describe the announcement bar"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "announcement",
      "name": "t:sections.header.blocks.announcement.name",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "t:sections.header.blocks.announcement.settings.text.label",
          "default": "Easy returns"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "t:sections.header.blocks.announcement.settings.link_text.label",
          "default": "30-day returns on all orders"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.header.blocks.announcement.settings.link.label"
        }
      ]
    }
  ],
  "default": {
    "settings": {}
  },
  "disabled_on": {
    "groups": ["footer", "custom.popups"]
  }
}
{% endschema %}
