{% doc %}
  @prompt
    Create a footer section feature that allows merchants to customize the background color, text color, and link color of the footer through theme editor settings. The footer should have color picker settings in the theme editor so merchants can easily change the footer's color scheme without editing code.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-footer-{{ ai_gen_id }} {
    display: block;
    background-color: {{ block.settings.footer_bg_color }};
    color: {{ block.settings.footer_text_color }};
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
    width: 100%;
  }

  .ai-footer-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-footer-content-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 40px;
    margin-bottom: 40px;
  }

  .ai-footer-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-footer-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    margin: 0 0 8px 0;
    color: {{ block.settings.footer_text_color }};
  }

  .ai-footer-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    margin: 0;
    color: {{ block.settings.footer_text_color }};
  }

  .ai-footer-link-{{ ai_gen_id }} {
    color: {{ block.settings.footer_link_color }};
    text-decoration: none;
    font-size: {{ block.settings.text_size }}px;
    transition: opacity 0.3s ease;
    display: inline-block;
  }

  .ai-footer-link-{{ ai_gen_id }}:hover {
    opacity: 0.7;
    color: {{ block.settings.footer_link_hover_color }};
  }

  .ai-footer-nav-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ai-footer-social-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .ai-footer-social-link-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background-color: {{ block.settings.footer_link_color }};
    color: {{ block.settings.footer_bg_color }};
    transition: transform 0.3s ease, background-color 0.3s ease;
  }

  .ai-footer-social-link-{{ ai_gen_id }}:hover {
    transform: scale(1.1);
    background-color: {{ block.settings.footer_link_hover_color }};
  }

  .ai-footer-social-link-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    fill: currentColor;
  }

  .ai-footer-bottom-{{ ai_gen_id }} {
    border-top: 1px solid {{ block.settings.footer_text_color }};
    padding-top: 24px;
    text-align: center;
    opacity: 0.8;
  }

  .ai-footer-copyright-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size | minus: 2 }}px;
    margin: 0;
    color: {{ block.settings.footer_text_color }};
  }

  @media screen and (max-width: 768px) {
    .ai-footer-content-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .ai-footer-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px 16px {{ block.settings.padding_bottom | times: 0.7 }}px;
    }
  }
{% endstyle %}

<footer class="ai-footer-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-footer-container-{{ ai_gen_id }}">
    <div class="ai-footer-content-{{ ai_gen_id }}">
      {% if block.settings.show_about %}
        <div class="ai-footer-column-{{ ai_gen_id }}">
          <h3 class="ai-footer-heading-{{ ai_gen_id }}">{{ block.settings.about_heading }}</h3>
          <div class="ai-footer-text-{{ ai_gen_id }}">
            {{ block.settings.about_text }}
          </div>
        </div>
      {% endif %}

      {% if block.settings.show_quick_links %}
        <div class="ai-footer-column-{{ ai_gen_id }}">
          <h3 class="ai-footer-heading-{{ ai_gen_id }}">{{ block.settings.quick_links_heading }}</h3>
          <ul class="ai-footer-nav-{{ ai_gen_id }}">
            {% if block.settings.link_1_text != blank and block.settings.link_1_url != blank %}
              <li>
                <a href="{{ block.settings.link_1_url }}" class="ai-footer-link-{{ ai_gen_id }}">
                  {{ block.settings.link_1_text }}
                </a>
              </li>
            {% endif %}
            {% if block.settings.link_2_text != blank and block.settings.link_2_url != blank %}
              <li>
                <a href="{{ block.settings.link_2_url }}" class="ai-footer-link-{{ ai_gen_id }}">
                  {{ block.settings.link_2_text }}
                </a>
              </li>
            {% endif %}
            {% if block.settings.link_3_text != blank and block.settings.link_3_url != blank %}
              <li>
                <a href="{{ block.settings.link_3_url }}" class="ai-footer-link-{{ ai_gen_id }}">
                  {{ block.settings.link_3_text }}
                </a>
              </li>
            {% endif %}
            {% if block.settings.link_4_text != blank and block.settings.link_4_url != blank %}
              <li>
                <a href="{{ block.settings.link_4_url }}" class="ai-footer-link-{{ ai_gen_id }}">
                  {{ block.settings.link_4_text }}
                </a>
              </li>
            {% endif %}
            {% if block.settings.link_5_text != blank and block.settings.link_5_url != blank %}
              <li>
                <a href="{{ block.settings.link_5_url }}" class="ai-footer-link-{{ ai_gen_id }}">
                  {{ block.settings.link_5_text }}
                </a>
              </li>
            {% endif %}
          </ul>
        </div>
      {% endif %}

      {% if block.settings.show_contact %}
        <div class="ai-footer-column-{{ ai_gen_id }}">
          <h3 class="ai-footer-heading-{{ ai_gen_id }}">{{ block.settings.contact_heading }}</h3>
          <div class="ai-footer-text-{{ ai_gen_id }}">
            {{ block.settings.contact_text }}
          </div>
          {% if block.settings.contact_email != blank %}
            <a href="mailto:{{ block.settings.contact_email }}" class="ai-footer-link-{{ ai_gen_id }}">
              {{ block.settings.contact_email }}
            </a>
          {% endif %}
          {% if block.settings.contact_phone != blank %}
            <a href="tel:{{ block.settings.contact_phone }}" class="ai-footer-link-{{ ai_gen_id }}">
              {{ block.settings.contact_phone }}
            </a>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.show_social %}
        <div class="ai-footer-column-{{ ai_gen_id }}">
          <h3 class="ai-footer-heading-{{ ai_gen_id }}">{{ block.settings.social_heading }}</h3>
          <div class="ai-footer-social-{{ ai_gen_id }}">
            {% if block.settings.facebook_url != blank %}
              <a href="{{ block.settings.facebook_url }}" class="ai-footer-social-link-{{ ai_gen_id }}" aria-label="Facebook" target="_blank" rel="noopener">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </a>
            {% endif %}
            {% if block.settings.instagram_url != blank %}
              <a href="{{ block.settings.instagram_url }}" class="ai-footer-social-link-{{ ai_gen_id }}" aria-label="Instagram" target="_blank" rel="noopener">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </a>
            {% endif %}
            {% if block.settings.twitter_url != blank %}
              <a href="{{ block.settings.twitter_url }}" class="ai-footer-social-link-{{ ai_gen_id }}" aria-label="Twitter" target="_blank" rel="noopener">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                </svg>
              </a>
            {% endif %}
            {% if block.settings.youtube_url != blank %}
              <a href="{{ block.settings.youtube_url }}" class="ai-footer-social-link-{{ ai_gen_id }}" aria-label="YouTube" target="_blank" rel="noopener">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              </a>
            {% endif %}
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-footer-bottom-{{ ai_gen_id }}">
      <p class="ai-footer-copyright-{{ ai_gen_id }}">
        {{ block.settings.copyright_text }}
      </p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "footer_bg_color",
      "label": "Background",
      "default": "#1f2937"
    },
    {
      "type": "color",
      "id": "footer_text_color",
      "label": "Text",
      "default": "#f3f4f6"
    },
    {
      "type": "color",
      "id": "footer_link_color",
      "label": "Link",
      "default": "#60a5fa"
    },
    {
      "type": "color",
      "id": "footer_link_hover_color",
      "label": "Link hover",
      "default": "#93c5fd"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "About section"
    },
    {
      "type": "checkbox",
      "id": "show_about",
      "label": "Show about section",
      "default": true
    },
    {
      "type": "text",
      "id": "about_heading",
      "label": "Heading",
      "default": "About Us"
    },
    {
      "type": "richtext",
      "id": "about_text",
      "label": "Text",
      "default": "<p>We are dedicated to providing quality products and excellent customer service.</p>"
    },
    {
      "type": "header",
      "content": "Quick links"
    },
    {
      "type": "checkbox",
      "id": "show_quick_links",
      "label": "Show quick links",
      "default": true
    },
    {
      "type": "text",
      "id": "quick_links_heading",
      "label": "Heading",
      "default": "Quick Links"
    },
    {
      "type": "text",
      "id": "link_1_text",
      "label": "Link 1 text",
      "default": "Search"
    },
    {
      "type": "url",
      "id": "link_1_url",
      "label": "Link 1 URL"
    },
    {
      "type": "text",
      "id": "link_2_text",
      "label": "Link 2 text",
      "default": "About Us"
    },
    {
      "type": "url",
      "id": "link_2_url",
      "label": "Link 2 URL"
    },
    {
      "type": "text",
      "id": "link_3_text",
      "label": "Link 3 text",
      "default": "Privacy Policy"
    },
    {
      "type": "url",
      "id": "link_3_url",
      "label": "Link 3 URL"
    },
    {
      "type": "text",
      "id": "link_4_text",
      "label": "Link 4 text",
      "default": "Refund Policy"
    },
    {
      "type": "url",
      "id": "link_4_url",
      "label": "Link 4 URL"
    },
    {
      "type": "text",
      "id": "link_5_text",
      "label": "Link 5 text",
      "default": "Contact"
    },
    {
      "type": "url",
      "id": "link_5_url",
      "label": "Link 5 URL"
    },
    {
      "type": "header",
      "content": "Contact section"
    },
    {
      "type": "checkbox",
      "id": "show_contact",
      "label": "Show contact section",
      "default": true
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Heading",
      "default": "Contact Us"
    },
    {
      "type": "richtext",
      "id": "contact_text",
      "label": "Address",
      "default": "<p>123 Main Street<br>City, State 12345</p>"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Email",
      "default": "info@example.com"
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Phone",
      "default": "+1 (555) 123-4567"
    },
    {
      "type": "header",
      "content": "Social media"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social media",
      "default": true
    },
    {
      "type": "text",
      "id": "social_heading",
      "label": "Heading",
      "default": "Follow Us"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "twitter_url",
      "label": "Twitter URL"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube URL"
    },
    {
      "type": "header",
      "content": "Copyright"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "© 2026 Your Store. All rights reserved."
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
