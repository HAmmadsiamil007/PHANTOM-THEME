{% style %}
  :root {
    /* ═══════════════════════════════════════════════════
       GRID SYSTEM
       Layout grid tokens for consistent page structure
       ═══════════════════════════════════════════════════ */

    /* Grid column count */
    --grid-columns: 12;
    --grid-columns-full: 14;
    --grid-columns-desktop-18: 18;

    /* Grid gap tokens (aliases to spacing scale) */
    --grid-gap: var(--space-4);
    --grid-gap-sm: var(--space-3);
    --grid-gap-lg: var(--space-6);
    --grid-gap-xl: var(--space-8);

    /* Column span utility tokens */
    --grid-col-1: 1;
    --grid-col-2: 2;
    --grid-col-3: 3;
    --grid-col-4: 4;
    --grid-col-5: 5;
    --grid-col-6: 6;
    --grid-col-7: 7;
    --grid-col-8: 8;
    --grid-col-9: 9;
    --grid-col-10: 10;
    --grid-col-11: 11;
    --grid-col-12: 12;

    /* Product grid columns */
    --product-grid-columns-mobile: 2;
    --product-grid-columns-desktop: 4;
    --product-grid-columns-wide: 5;
    --product-grid-gap: var(--space-4);

    /* Section grid layout tokens */
    --full-page-grid-margin: minmax(var(--page-margin, 16px), 1fr);
    --full-page-grid-central: minmax(0, calc(100% - var(--page-margin, 16px) * 2));
    --full-page-grid: var(--full-page-grid-margin) var(--full-page-grid-central) var(--full-page-grid-margin);

    /* Resource list (carousel/grid) column counts */
    --resource-list-columns-mobile: 2;
    --resource-list-columns-tablet: 3;
    --resource-list-columns-desktop: 4;
  }
{% endstyle %}
