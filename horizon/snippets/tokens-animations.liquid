{% style %}
  :root {
    /* ═══════════════════════════════════════════════════
       ANIMATION TOKENS
       Duration, easing, and motion presets
       ═══════════════════════════════════════════════════ */

    /* Animation durations */
    --duration-instant: 0s;
    --duration-fastest: 50ms;
    --duration-faster: 75ms;
    --duration-fast: 100ms;
    --duration-normal: 150ms;
    --duration-slow: 200ms;
    --duration-slower: 300ms;
    --duration-slowest: 500ms;
    --duration-xslow: 800ms;

    /* Easing curves */
    --ease-linear: linear;
    --ease-in: cubic-bezier(0.4, 0, 1, 1);
    --ease-out: cubic-bezier(0, 0, 0.2, 1);
    --ease-in-out: cubic-bezier(0.4, 0, 0.2, 1);

    --ease-out-cubic: cubic-bezier(0.33, 1, 0.68, 1);
    --ease-out-quad: cubic-bezier(0.32, 0.72, 0, 1);
    --ease-out-quart: cubic-bezier(0.22, 1, 0.36, 1);
    --ease-out-expo: cubic-bezier(0.19, 1, 0.22, 1);
    --ease-out-back: cubic-bezier(0.34, 1.56, 0.64, 1);

    --ease-in-out-quad: cubic-bezier(0.455, 0.03, 0.515, 0.955);
    --ease-in-out-cubic: cubic-bezier(0.65, 0, 0.35, 1);
    --ease-in-out-expo: cubic-bezier(0.87, 0, 0.13, 1);

    /* Spring-like easing (bouncy but controlled) */
    --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
    --ease-bounce: cubic-bezier(0.34, 1.56, 0.64, 1);

    /* Interaction easings */
    --ease-hover: cubic-bezier(0.25, 0.46, 0.45, 0.94);
    --ease-active: cubic-bezier(0.5, 0, 0.75, 0);
    --ease-fade-in: cubic-bezier(0.16, 1, 0.3, 1);
    --ease-fade-out: cubic-bezier(0.4, 0, 0.2, 1);

    /* Motion presets (duration + easing combined) */
    --motion-fastest: var(--duration-fastest) var(--ease-out);
    --motion-faster: var(--duration-faster) var(--ease-out);
    --motion-fast: var(--duration-fast) var(--ease-out);
    --motion-normal: var(--duration-normal) var(--ease-out);
    --motion-slow: var(--duration-slow) var(--ease-out);
    --motion-slower: var(--duration-slower) var(--ease-out-quart);
    --motion-slowest: var(--duration-slowest) var(--ease-out-quart);

    /* Cascade / stagger delays */
    --stagger-fast: 30ms;
    --stagger-normal: 50ms;
    --stagger-slow: 80ms;

    /* Legacy animation tokens (ensuring backward compat) */
    --animation-speed-fast: var(--duration-fast);
    --animation-speed: var(--duration-normal);
    --animation-speed-slow: var(--duration-slow);
    --animation-speed-medium: var(--duration-normal);
    --animation-easing: var(--ease-in-out);
    --animation-slideshow-easing: var(--ease-out-cubic);
    --drawer-animation-speed: var(--duration-slow);

    --animation-values-fast: var(--animation-speed-fast) var(--animation-easing);
    --animation-values: var(--animation-speed) var(--animation-easing);
    --animation-values-slow: var(--animation-speed-slow) var(--animation-easing);
    --animation-values-allow-discrete: var(--animation-speed) var(--animation-easing) allow-discrete;

    --animation-timing-hover: var(--ease-hover);
    --animation-timing-active: var(--ease-active);
    --animation-timing-bounce: var(--ease-spring);
    --animation-timing-default: var(--ease-out);
    --animation-timing-fade-in: var(--ease-fade-in);
    --animation-timing-fade-out: var(--ease-fade-out);

    /* Submenu animation */
    --submenu-animation-speed: 360ms;
    --submenu-animation-easing: cubic-bezier(0.25, 0.1, 0.25, 1);

    /* Shimmer skeleton */
    --shimmer-speed: 1.25s;
  }
{% endstyle %}
