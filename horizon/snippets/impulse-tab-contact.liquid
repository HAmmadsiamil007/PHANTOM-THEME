{%- assign contact_form_id = 'contact-' | append: id -%}

{%- style -%}
  .impulse-tab-contact__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 14px 16px;
    font-size: 0.95em;
    font-weight: 600;
    text-align: left;
    background: none;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .impulse-tab-contact__trigger:hover {
    background: rgb(var(--color-foreground-rgb) / 0.03);
  }

  .impulse-tab-contact__trigger.is-open {
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
  }

  .impulse-tab-contact__icon {
    width: 12px;
    height: 12px;
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }

  .impulse-tab-contact__trigger.is-open .impulse-tab-contact__icon {
    transform: rotate(180deg);
  }

  .impulse-tab-contact__content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
    border-top: none;
    border-radius: 0 0 4px 4px;
  }

  .impulse-tab-contact__content.is-open {
    max-height: 600px;
    padding: 16px;
  }

  .impulse-tab-contact__form label {
    display: block;
    margin-bottom: 4px;
    font-size: 0.85em;
    font-weight: 500;
  }

  .impulse-tab-contact__form input,
  .impulse-tab-contact__form textarea {
    width: 100%;
    padding: 10px 12px;
    margin-bottom: 12px;
    font-size: 0.9em;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.15);
    border-radius: 4px;
    background: transparent;
    color: inherit;
  }

  .impulse-tab-contact__form .btn {
    display: inline-block;
    padding: 10px 24px;
    font-size: 0.9em;
    font-weight: 600;
    color: #fff;
    background: #000;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .impulse-tab-contact__form .btn:hover {
    opacity: 0.85;
  }

  .impulse-tab-contact__form .note--success {
    padding: 10px 14px;
    margin-bottom: 12px;
    font-size: 0.85em;
    color: #166534;
    background: #dcfce7;
    border-radius: 4px;
  }
{%- endstyle -%}

<div class="impulse-tab-wrapper" style="margin-bottom: 8px;">
  {%- form 'contact', id: contact_form_id -%}
    <button type="button" class="impulse-tab-contact__trigger" aria-expanded="false">
      {{ title | default: 'Contact us' }}
      <svg class="impulse-tab-contact__icon" viewBox="0 0 28 16" fill="none" stroke="currentColor" stroke-width="2">
        <path d="m1.57 1.59 12.76 12.77L27.1 1.59"/>
      </svg>
    </button>

    <div class="impulse-tab-contact__content">
      <div class="impulse-tab-contact__form">
        <input type="hidden" name="contact[product]" value="Product question for: {{ shop.secure_url }}{{ product.url }}">

        <label for="ContactFormName-{{ id }}">Name</label>
        <input type="text" id="ContactFormName-{{ id }}" name="contact[name]" autocapitalize="words" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}">

        <label for="ContactFormEmail-{{ id }}">Email</label>
        <input type="email" id="ContactFormEmail-{{ id }}" name="contact[email]" autocorrect="off" autocapitalize="off" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}">

        {%- if show_phone -%}
          <label for="ContactFormPhone-{{ id }}">Phone</label>
          <input type="tel" id="ContactFormPhone-{{ id }}" name="contact[phone]" pattern="[0-9\-]*" value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}">
        {%- endif -%}

        <label for="ContactFormMessage-{{ id }}">Message</label>
        <textarea rows="5" id="ContactFormMessage-{{ id }}" name="contact[body]">{% if form.body %}{{ form.body }}{% endif %}</textarea>

        <button type="submit" class="btn">
          Send
        </button>
      </div>
    </div>

    {%- if form.posted_successfully? -%}
      <p class="note note--success">
        Thank you for your message. We'll get back to you soon.
      </p>
    {%- endif -%}

    {%- if form.errors -%}
      {{ form.errors | default_errors }}
    {%- endif -%}
  {%- endform -%}
</div>

{%- javascript -%}
  (function() {
    var triggers = document.querySelectorAll('.impulse-tab-contact__trigger');
    triggers.forEach(function(trigger) {
      trigger.addEventListener('click', function() {
        var content = this.nextElementSibling;
        var isOpen = this.classList.toggle('is-open');
        content.classList.toggle('is-open');
        this.setAttribute('aria-expanded', isOpen);
      });
    });
  })();
{%- endjavascript -%}
