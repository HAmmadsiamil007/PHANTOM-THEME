{% style %}
  :root {
    /* ═══════════════════════════════════════════════
       TYPOGRAPHY SCALE
       Systematic type scale based on 1.25 ratio
       ═══════════════════════════════════════════════ */

    /* Base scale in rem (root em = 16px default) */
    --text-3xs: 0.5rem;     /* 8px  */
    --text-2xs: 0.625rem;   /* 10px */
    --text-xs: 0.75rem;     /* 12px */
    --text-sm: 0.8125rem;   /* 13px */
    --text-base: 0.875rem;  /* 14px — Horizon body default */
    --text-md: 1rem;        /* 16px */
    --text-lg: 1.125rem;    /* 18px */
    --text-xl: 1.25rem;     /* 20px */
    --text-2xl: 1.5rem;     /* 24px */
    --text-3xl: 2rem;       /* 32px */
    --text-4xl: 2.5rem;     /* 40px */
    --text-5xl: 3rem;       /* 48px */
    --text-6xl: 3.5rem;     /* 56px */
    --text-7xl: 4.5rem;     /* 72px */
    --text-8xl: 5.5rem;     /* 88px */
    --text-9xl: 7.5rem;     /* 120px */
    --text-10xl: 9.5rem;    /* 152px */
    --text-11xl: 11.5rem;   /* 184px */

    /* Fluid type scale (clamp values for responsive headings) */
    --text-fluid-sm: clamp(0.875rem, 0.8rem + 0.25vw, 1rem);
    --text-fluid-base: clamp(1rem, 0.9rem + 0.35vw, 1.125rem);
    --text-fluid-lg: clamp(1.125rem, 1rem + 0.5vw, 1.375rem);
    --text-fluid-xl: clamp(1.25rem, 1.1rem + 0.7vw, 1.75rem);
    --text-fluid-2xl: clamp(1.5rem, 1.2rem + 1vw, 2.25rem);
    --text-fluid-3xl: clamp(2rem, 1.5rem + 1.5vw, 3rem);
    --text-fluid-4xl: clamp(2.5rem, 1.8rem + 2vw, 4rem);
    --text-fluid-5xl: clamp(3rem, 2rem + 2.5vw, 5rem);
    --text-fluid-6xl: clamp(3.5rem, 2.2rem + 3vw, 6rem);

    /* Line height scale */
    --leading-none: 1;
    --leading-tight: 1.1;
    --leading-snug: 1.2;
    --leading-normal: 1.4;
    --leading-relaxed: 1.6;
    --leading-loose: 1.8;

    /* Letter spacing scale */
    --tracking-tighter: -0.05em;
    --tracking-tight: -0.025em;
    --tracking-normal: 0em;
    --tracking-wide: 0.025em;
    --tracking-wider: 0.05em;
    --tracking-widest: 0.1em;

    /* Font weight tokens */
    --weight-thin: 100;
    --weight-extralight: 200;
    --weight-light: 300;
    --weight-normal: 400;
    --weight-medium: 500;
    --weight-semibold: 600;
    --weight-bold: 700;
    --weight-extrabold: 800;
    --weight-black: 900;

    /* Text transform */
    --case-none: none;
    --case-uppercase: uppercase;
    --case-lowercase: lowercase;
    --case-capitalize: capitalize;

    /* Text wrapping */
    --text-wrap-balance: balance;
    --text-wrap-pretty: pretty;
  }
{% endstyle %}
