        { "value": "var(--font-accent--family)", "label": "Theme accent font" }
      ],
      "default": ""
    },
    {
      "type": "range",
      "id": "token_base_size",
      "label": "Base font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 0,
      "unit": "px",
      "info": "Set to 0 to use global default"
    },
    {
      "type": "range",
      "id": "token_heading_scale",
      "label": "Heading scale multiplier",
      "min": 100,
      "max": 200,
      "step": 10,
      "default": 0,
      "unit": "%",
      "info": "100% = global default. Set to 0 to use global default"
    },
    {
      "type": "range",
      "id": "token_letter_spacing",
      "label": "Letter spacing",
