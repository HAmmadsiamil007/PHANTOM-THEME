      "info": "Override global typography tokens for this section only"
    },
    {
      "type": "select",
      "id": "token_heading_font",
      "label": "Heading font family",
      "options": [
        { "value": "", "label": "Use global default" },
        { "value": "var(--font-heading--family)", "label": "Theme heading font" },
        { "value": "var(--font-body--family)", "label": "Theme body font" },
        { "value": "var(--font-accent--family)", "label": "Theme accent font" }
      ],
      "default": ""
