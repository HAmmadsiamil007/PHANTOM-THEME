{% style %}
  :root {
    /* ═══════════════════════════════════════════════════
       ILLUSTRATION SYSTEM
       Sizing and layout tokens for illustrations
       ═══════════════════════════════════════════════════ */

    /* Illustration size scale */
    --illus-xs: 2rem;         /* 32px  */
    --illus-sm: 3rem;         /* 48px  */
    --illus-md: 4rem;         /* 64px  */
    --illus-lg: 6rem;         /* 96px  */
    --illus-xl: 8rem;         /* 128px */
    --illus-2xl: 10rem;       /* 160px */
    --illus-3xl: 12rem;       /* 192px */
    --illus-4xl: 14rem;       /* 224px */
    --illus-5xl: 16rem;       /* 256px */
    --illus-6xl: 20rem;       /* 320px */
    --illus-7xl: 24rem;       /* 384px */
    --illus-8xl: 28rem;       /* 448px */
    --illus-full: 100%;

    /* Illustration color tokens */
    --illus-primary: var(--color-foreground);
    --illus-secondary: rgb(var(--color-foreground-rgb) / 0.7);
    --illus-tertiary: rgb(var(--color-foreground-rgb) / 0.4);
    --illus-background: rgb(var(--color-foreground-rgb) / 0.05);
    --illus-accent: var(--color-foreground);

    /* Empty state illustration */
    --illus-empty-state-width: 12rem;
    --illus-empty-state-height: auto;

    /* Placeholder (SVG placeholder) */
    --placeholder-bg: rgb(var(--color-foreground-rgb) / 0.05);
    --placeholder-color: rgb(var(--color-foreground-rgb) / 0.15);

    /* Hero illustration */
    --illus-hero-width: 100%;
    --illus-hero-max-height: 70vh;

    /* Badge/emoji-style illustrations */
    --illus-badge: 2.5rem;
    --illus-icon-illus: 1.5rem;
  }
{% endstyle %}
