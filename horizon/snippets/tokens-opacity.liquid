{% style %}
  :root {
    /* ═══════════════════════════════════════════════════
       OPACITY TOKENS
       Systematic opacity values for UI layering
       ═══════════════════════════════════════════════════ */

    /* Ghost → Full spectrum */
    --opacity-0: 0;
    --opacity-5: 0.05;
    --opacity-8: 0.08;
    --opacity-10: 0.1;
    --opacity-12: 0.12;
    --opacity-15: 0.15;
    --opacity-20: 0.2;
    --opacity-25: 0.25;
    --opacity-30: 0.3;
    --opacity-35: 0.35;
    --opacity-40: 0.4;
    --opacity-45: 0.45;
    --opacity-50: 0.5;
    --opacity-55: 0.55;
    --opacity-60: 0.6;
    --opacity-65: 0.65;
    --opacity-70: 0.7;
    --opacity-75: 0.75;
    --opacity-80: 0.8;
    --opacity-85: 0.85;
    --opacity-90: 0.9;
    --opacity-95: 0.95;
    --opacity-100: 1;

    /* Semantic opacity tokens */
    --opacity-disabled: 0.5;
    --opacity-muted: 0.6;
    --opacity-subdued: 0.8;
    --opacity-skeleton: 0.025;
    --opacity-hover: 0.8;
    --opacity-active: 0.9;
    --opacity-scrim: 0.5;
    --opacity-backdrop: 0.15;

    /* Combined boundary opacity values (used in theme) */
    --opacity-5-15: 0.08;
    --opacity-10-25: 0.15;
    --opacity-35-55: 0.45;
    --opacity-40-60: 0.5;
  }
{% endstyle %}
