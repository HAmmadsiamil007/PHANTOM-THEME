{% style %}
  :root {
    /* ═══════════════════════════════════════════════════
       CONTAINER WIDTHS
       Page and content container constraints
       ═══════════════════════════════════════════════════ */

    /* Page widths (from theme settings) */
    --page-width-narrow: 90rem;    /* 1440px */
    --page-width-normal: 120rem;   /* 1920px */
    --page-width-wide: 150rem;     /* 2400px */
    --page-width-content: 42rem;   /* 672px - narrow content */

    /* Content widths */
    --content-narrow: 36rem;       /* 576px */
    --content-normal: 42rem;       /* 672px */
    --content-wide: 46rem;         /* 736px */

    /* Section heights */
    --section-height-sm: 15rem;    /* 240px */
    --section-height-md: 25rem;    /* 400px */
    --section-height-lg: 35rem;    /* 560px */

    /* Sidebar / drawer widths */
    --sidebar-width: 25rem;        /* 400px */
    --drawer-width: 30rem;         /* 480px */
    --drawer-max-width: 500px;

    /* Modal widths */
    --modal-width-sm: 32rem;       /* 512px */
    --modal-width-md: 42rem;       /* 672px */
    --modal-width-lg: 54rem;       /* 864px */
    --modal-max-width: 96vw;
    --modal-max-height: 65dvh;

    /* Quick add modal */
    --quick-add-modal-width: min(54rem, 96vw);
    --quick-add-modal-height: min(38.5rem, 96vh);
    --quick-add-modal-gallery-width: 24rem;  /* 384px */

    /* Container max-widths */
    --container-max-sm: 640px;
    --container-max-md: 768px;
    --container-max-lg: 1024px;
    --container-max-xl: 1280px;
    --container-max-2xl: 1536px;

    /* Input widths */
    --input-email-min-width: 200px;
    --input-search-max-width: 650px;

    /* Min touch target */
    --minimum-touch-target: 44px;

    /* Line length (readability) */
    --max-line-length: 65ch;
    --max-line-length-narrow: 45ch;

    /* Header heights (set dynamically via JS) */
    --header-height: 0px;
    --header-group-height: 0px;
    --top-row-height: 0px;
  }
{% endstyle %}
