

{% liquid
  if section.settings.background_color != blank
    render 'contrast-override', background_color: section.settings.background_color, section_id: section.id
  endif
%}

{% render 'section-tokens', settings: section.settings, section_id: section.id %}

{% render 'section-visibility', settings: section.settings, section_id: section.id %}

<div
  class="section-background{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %} px-mobile-3"
></div>
<div class="section page-width-content{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}">
  <div
    class="
      spacing-style
      layout-panel-flex
      layout-panel-flex--column
      section-content-wrapper
      mobile-column
    "
    style="
      {% render 'layout-panel-style', settings: section.settings %}
      {% render 'spacing-style', settings: section.settings %}
    "
  >
    {% content_for 'blocks' %}
  </div>
</div>

{% schema %}
{
  "name": "t:names.page",
  "class": "section-wrapper",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "_divider"
    }
  ],
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "select",
      "id": "content_direction",
      "label": "t:settings.direction",
      "options": [
        {
          "value": "column",
          "label": "t:options.vertical"
        }
      ],
      "default": "column",
      "visible_if": "{{ section.settings.gap < 0 }}"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "placeholder": "t:settings.default"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }

    {
      "type": "header",
      "content": "⚡ Design Tokens",
      "info": "Override global design tokens for this section only. Leave blank to use global defaults."
    },
    {
      "type": "color",
      "id": "token_primary_color",
      "label": "Primary accent",
      "placeholder": "Global default"
    },
    {
      "type": "color",
      "id": "token_text_color",
      "label": "Text color",
      "placeholder": "Global default"
    },
    {
      "type": "color",
      "id": "token_bg_color",
      "label": "Background",
      "placeholder": "Global default"
    },
    {
      "type": "color",
      "id": "token_heading_color",
      "label": "Heading color",
      "placeholder": "Global default"
    },
    {
      "type": "color",
      "id": "token_accent_color",
      "label": "Accent/highlight",
      "placeholder": "Global default"
    },
    {
      "type": "range",
      "id": "token_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "token_heading_font",
      "label": "Heading font",
      "options": [
        { "value": "", "label": "Global default" },
        { "value": "var(--font-heading--family)", "label": "Heading font" },
        { "value": "var(--font-body--family)", "label": "Body font" }
      ],
      "default": ""
    }
      {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Hide on mobile",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_on_desktop",
      "label": "Hide on desktop",
      "default": false
    }
  ]
}
{% endschema %}
