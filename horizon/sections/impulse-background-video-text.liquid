<style>
  .impulse-background-video-text {
    position: relative;
    overflow: hidden;
  }
  .impulse-background-video-text .background-media-text__video {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    overflow: hidden;
    background: #000;
  }
  .impulse-background-video-text .background-media-text__video iframe,
  .impulse-background-video-text .background-media-text__video video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: 0;
  }
  .impulse-background-video-text .background-media-text__video .vimeo-mobile-trigger {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
    background: rgba(255,255,255,0.9);
    border: 0;
    border-radius: 50%;
    width: 60px;
    height: 60px;
    cursor: pointer;
  }
  .impulse-background-video-text .background-media-text__video .vimeo-mobile-trigger svg {
    width: 24px;
    height: 28px;
    margin-left: 3px;
  }
  .impulse-background-video-text .background-media-text__inner {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
  .impulse-background-video-text .background-media-text__aligner {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 60px;
  }
  .impulse-background-video-text .background-media-text--right .background-media-text__aligner {
    text-align: right;
  }
  .impulse-background-video-text .background-media-text__text {
    display: inline-block;
    pointer-events: auto;
    max-width: 500px;
    padding: 30px;
    background: #fff;
    text-align: left;
  }
  .impulse-background-video-text .background-media-text__text p.h5 {
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin: 0 0 5px;
  }
  .impulse-background-video-text .background-media-text__text p.h3 {
    font-size: 24px;
    margin: 0 0 15px;
  }
  .impulse-background-video-text .background-media-text__subtext p {
    font-size: 14px;
    line-height: 1.6;
    margin: 0 0 15px;
  }
  .impulse-background-video-text .background-media-text__subtext p:last-child {
    margin-bottom: 0;
  }
  .impulse-background-video-text .animation-cropper {
    overflow: hidden;
  }
  .impulse-background-video-text .animation-contents {
    opacity: 1;
  }
  .impulse-background-video-text .btn {
    display: inline-flex;
    align-items: center;
    padding: 10px 24px;
    background: #000;
    color: #fff;
    text-decoration: none;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    border: 0;
    cursor: pointer;
  }
  .impulse-background-video-text .btn:hover {
    background: #333;
  }
  .impulse-background-video-text .btn .icon-play {
    width: 24px;
    height: 28px;
    fill: #fff;
    display: block;
  }
  .impulse-background-video-text .text-spacing {
    letter-spacing: 0.05em;
  }
  .impulse-background-video-text.background-media-text--450 { min-height: 450px; }
  .impulse-background-video-text.background-media-text--550 { min-height: 550px; }
  .impulse-background-video-text.background-media-text--650 { min-height: 650px; }
  .impulse-background-video-text.background-media-text--750 { min-height: 750px; }
  .impulse-background-video-text-space {
    display: block;
  }
  .impulse-background-video-text-space.background-media-text--450 { padding-top: 450px; }
  .impulse-background-video-text-space.background-media-text--550 { padding-top: 550px; }
  .impulse-background-video-text-space.background-media-text--650 { padding-top: 650px; }
  .impulse-background-video-text-space.background-media-text--750 { padding-top: 750px; }

  @media only screen and (max-width: 749px) {
    .impulse-background-video-text .background-media-text__aligner {
      padding: 20px;
    }
    .impulse-background-video-text .background-media-text__text {
      max-width: 100%;
    }
  }

  @media screen and (max-width: 768px) {
    .background-media-text--{{ section.id }} {
      background: {{ section.settings.color_border }};
    }
  }
</style>

<div
  data-section-id="{{ section.id }}"
  data-section-type="video-section"
  class="impulse-background-video-text background-media-text--{{ section.id }} background-media-text--{{ section.settings.height }}"
  data-aos="background-media-text__animation">

  <div class="background-media-text__video">
    {%- render 'impulse-video-div', section_id: section.id, url: section.settings.video_url -%}
  </div>

  {%- if section.settings.subtitle != blank or section.settings.title != blank or section.settings.text != blank -%}
    <div class="background-media-text__inner">
      <div class="background-media-text__aligner background-media-text--{{ section.settings.layout }}">
        <div class="animation-cropper">
          <div class="animation-contents">
            <div class="background-media-text__text">
              {%- if section.settings.subtitle -%}
                <p class="h5">{{ section.settings.subtitle }}</p>
              {%- endif -%}
              {%- if section.settings.title != blank -%}
                <p class="h3 text-spacing">{{ section.settings.title | escape }}</p>
              {%- endif -%}
              {%- if section.settings.text != blank -%}
                <div class="rte background-media-text__subtext">{{ section.settings.text }}</div>
              {%- endif -%}

              {%- if section.settings.button_label != blank -%}
                {%- assign link_href = section.settings.button_link -%}
                {%- if section.settings.button_link == blank -%}
                  {%- assign link_href = section.settings.video_url -%}
                {%- endif -%}

                <a href="{{ link_href }}" class="btn">
                  {%- if link_href contains 'youtube.com/watch' or link_href contains 'youtu.be/' -%}
                    <span style="padding-right: 5px;">
                      <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-play" viewBox="18.24 17.35 24.52 28.3"><path fill="#323232" d="M22.1 19.151v25.5l20.4-13.489-20.4-12.011z"/></svg>
                    </span>
                  {%- endif -%}
                  {{ section.settings.button_label }}
                </a>
              {%- endif -%}
            </div>
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}
</div>

<div class="impulse-background-video-text-space background-media-text--{{ section.settings.height }}"></div>

{% schema %}
{
  "name": "Background video text",
  "class": "index-section--flush",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Just launched"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Watch what\u2019s next"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Take a closer look at the movement, materials, and details behind the latest drop.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "info": "Leave blank to link to video URL"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL",
      "default": "https://www.youtube.com/watch?v=_9VUPq3SxOc",
      "info": "Supports YouTube, Vimeo, or .mp4"
    },
    {
      "type": "color",
      "id": "color_border",
      "label": "Mobile background color",
      "default": "#f4f4f4"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Text position",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "height",
      "label": "Section height",
      "default": 550,
      "min": 450,
      "max": 750,
      "step": 100,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Background video text",
      "category": "Banners"
    }
  ],
  "disabled_on": {
    "groups": ["footer", "header", "custom.popups"]
  }
}
{% endschema %}
