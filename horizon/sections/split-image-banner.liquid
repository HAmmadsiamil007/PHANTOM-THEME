{% doc %}
  @prompt
    Create a Premium Split Image Banner Section for Shopify OS 2.0 with a responsive 50/50 layout. Include separate Left and Right banners, each with Desktop Image, Mobile Image, Heading, Subheading, Description, Badge, Primary & Secondary Buttons, Links, and Overlay Content. Add a toggle to use separate mobile images and a toggle to stack or keep split layout on mobile.
    
    Include full customization controls: Font Pickers, Color Pickers, Desktop/Tablet/Mobile font sizes, text alignment, content positioning, image height, aspect ratio, overlay colors & opacity, border radius, spacing, padding, margins, section width (boxed/full-width), hover effects, animations, badges, and button styles.
    
    Add mobile-specific settings for image selection, content alignment, spacing, button width, and layout order. Support lazy loading, accessibility, SEO optimization, Dynamic Sources, and complete Shopify OS 2.0 schema settings with clean, high-performance code.
{% enddoc %}
{% assign ai_gen_id = section.id | replace: '_', '' | downcase %}

{% style %}
  .ai-split-banner-{{ ai_gen_id }} {
    width: 100%;
    display: block;
  }

  .ai-split-banner-container-{{ ai_gen_id }} {
    {% if section.settings.section_width == 'boxed' %}
      max-width: {{ section.settings.container_max_width }}px;
      margin-left: auto;
      margin-right: auto;
      padding-left: 20px;
      padding-right: 20px;
    {% else %}
      width: 100%;
      max-width: 100%;
    {% endif %}
  }

  .ai-split-banner-wrapper-{{ ai_gen_id }} {
    display: flex;
    margin-top: {{ section.settings.section_margin_top }}px;
    margin-bottom: {{ section.settings.section_margin_bottom }}px;
    gap: {{ section.settings.gap_between_banners }}px;
  }

  .ai-split-banner-item-{{ ai_gen_id }} {
    position: relative;
    flex: 1;
    min-width: 0;
    overflow: hidden;
    border-radius: {{ section.settings.border_radius }}px;
    {% if section.settings.enable_hover_effect %}
      transition: transform 0.3s ease;
    {% endif %}
  }

  {% if section.settings.enable_hover_effect %}
    .ai-split-banner-item-{{ ai_gen_id }}:hover {
      transform: scale(1.02);
    }
  {% endif %}

  .ai-split-banner-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ section.settings.image_height_desktop }}px;
    overflow: hidden;
  }

  .ai-split-banner-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    {% if section.settings.enable_image_animation %}
      transition: transform 0.5s ease;
    {% endif %}
  }

  {% if section.settings.enable_image_animation %}
    .ai-split-banner-item-{{ ai_gen_id }}:hover .ai-split-banner-image-{{ ai_gen_id }} {
      transform: scale(1.1);
    }
  {% endif %}

  .ai-split-banner-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }

  .ai-split-banner-content-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    padding: {{ section.settings.content_padding }}px;
    z-index: 2;
  }

  .ai-split-banner-content-inner-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ section.settings.content_max_width }}px;
  }

  .ai-split-banner-badge-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ section.settings.badge_padding_y }}px {{ section.settings.badge_padding_x }}px;
    background-color: {{ section.settings.badge_bg_color }};
    color: {{ section.settings.badge_text_color }};
    font-size: {{ section.settings.badge_font_size_desktop }}px;
    font-weight: {{ section.settings.badge_font_weight }};
    border-radius: {{ section.settings.badge_border_radius }}px;
    margin-bottom: {{ section.settings.badge_margin_bottom }}px;
    text-transform: {{ section.settings.badge_text_transform }};
  }

  .ai-split-banner-heading-{{ ai_gen_id }} {
    font-family: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }};
    font-weight: {{ section.settings.heading_font.weight }};
    font-size: {{ section.settings.heading_font_size_desktop }}px;
    line-height: {{ section.settings.heading_line_height }};
    color: {{ section.settings.heading_color }};
    margin: 0 0 {{ section.settings.heading_margin_bottom }}px 0;
    text-transform: {{ section.settings.heading_text_transform }};
    letter-spacing: {{ section.settings.heading_letter_spacing }}px;
  }

  .ai-split-banner-subheading-{{ ai_gen_id }} {
    font-family: {{ section.settings.subheading_font.family }}, {{ section.settings.subheading_font.fallback_families }};
    font-weight: {{ section.settings.subheading_font.weight }};
    font-size: {{ section.settings.subheading_font_size_desktop }}px;
    line-height: {{ section.settings.subheading_line_height }};
    color: {{ section.settings.subheading_color }};
    margin: 0 0 {{ section.settings.subheading_margin_bottom }}px 0;
    text-transform: {{ section.settings.subheading_text_transform }};
  }

  .ai-split-banner-description-{{ ai_gen_id }} {
    font-family: {{ section.settings.description_font.family }}, {{ section.settings.description_font.fallback_families }};
    font-weight: {{ section.settings.description_font.weight }};
    font-size: {{ section.settings.description_font_size_desktop }}px;
    line-height: {{ section.settings.description_line_height }};
    color: {{ section.settings.description_color }};
    margin: 0 0 {{ section.settings.description_margin_bottom }}px 0;
  }

  .ai-split-banner-buttons-{{ ai_gen_id }} {
    display: flex;
    gap: {{ section.settings.button_gap }}px;
    flex-wrap: wrap;
  }

  .ai-split-banner-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ section.settings.button_padding_y }}px {{ section.settings.button_padding_x }}px;
    font-size: {{ section.settings.button_font_size_desktop }}px;
    font-weight: {{ section.settings.button_font_weight }};
    text-decoration: none;
    border-radius: {{ section.settings.button_border_radius }}px;
    transition: all 0.3s ease;
    border: {{ section.settings.button_border_width }}px solid;
    text-transform: {{ section.settings.button_text_transform }};
    letter-spacing: {{ section.settings.button_letter_spacing }}px;
  }

  .ai-split-banner-button-primary-{{ ai_gen_id }} {
    background-color: {{ section.settings.button_primary_bg }};
    color: {{ section.settings.button_primary_text }};
    border-color: {{ section.settings.button_primary_border }};
  }

  .ai-split-banner-button-primary-{{ ai_gen_id }}:hover {
    background-color: {{ section.settings.button_primary_bg_hover }};
    color: {{ section.settings.button_primary_text_hover }};
    border-color: {{ section.settings.button_primary_border_hover }};
  }

  .ai-split-banner-button-secondary-{{ ai_gen_id }} {
    background-color: {{ section.settings.button_secondary_bg }};
    color: {{ section.settings.button_secondary_text }};
    border-color: {{ section.settings.button_secondary_border }};
  }

  .ai-split-banner-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ section.settings.button_secondary_bg_hover }};
    color: {{ section.settings.button_secondary_text_hover }};
    border-color: {{ section.settings.button_secondary_border_hover }};
  }

  .ai-split-banner-content-left-{{ ai_gen_id }} {
    align-items: {{ section.settings.content_position_vertical_left }};
    text-align: {{ section.settings.text_align_left }};
  }

  .ai-split-banner-content-right-{{ ai_gen_id }} {
    align-items: {{ section.settings.content_position_vertical_right }};
    text-align: {{ section.settings.text_align_right }};
  }

  .ai-split-banner-content-left-{{ ai_gen_id }}.ai-split-banner-align-center-{{ ai_gen_id }} {
    justify-content: center;
  }

  .ai-split-banner-content-left-{{ ai_gen_id }}.ai-split-banner-align-right-{{ ai_gen_id }} {
    justify-content: flex-end;
  }

  .ai-split-banner-content-right-{{ ai_gen_id }}.ai-split-banner-align-center-{{ ai_gen_id }} {
    justify-content: center;
  }

  .ai-split-banner-content-right-{{ ai_gen_id }}.ai-split-banner-align-right-{{ ai_gen_id }} {
    justify-content: flex-end;
  }

  @media (max-width: 991px) {
    .ai-split-banner-image-wrapper-{{ ai_gen_id }} {
      height: {{ section.settings.image_height_tablet }}px;
    }

    .ai-split-banner-heading-{{ ai_gen_id }} {
      font-size: {{ section.settings.heading_font_size_tablet }}px;
    }

    .ai-split-banner-subheading-{{ ai_gen_id }} {
      font-size: {{ section.settings.subheading_font_size_tablet }}px;
    }

    .ai-split-banner-description-{{ ai_gen_id }} {
      font-size: {{ section.settings.description_font_size_tablet }}px;
    }

    .ai-split-banner-button-{{ ai_gen_id }} {
      font-size: {{ section.settings.button_font_size_tablet }}px;
    }

    .ai-split-banner-badge-{{ ai_gen_id }} {
      font-size: {{ section.settings.badge_font_size_tablet }}px;
    }
  }

  @media (max-width: 767px) {
    .ai-split-banner-wrapper-{{ ai_gen_id }} {
      {% if section.settings.mobile_layout == 'stacked' %}
        flex-direction: column;
      {% endif %}
      gap: {{ section.settings.gap_between_banners_mobile }}px;
    }

    {% if section.settings.mobile_layout == 'stacked' and section.settings.mobile_reverse_order %}
      .ai-split-banner-wrapper-{{ ai_gen_id }} {
        flex-direction: column-reverse;
      }
    {% endif %}

    .ai-split-banner-image-wrapper-{{ ai_gen_id }} {
      height: {{ section.settings.image_height_mobile }}px;
    }

    .ai-split-banner-content-{{ ai_gen_id }} {
      padding: {{ section.settings.content_padding_mobile }}px;
    }

    .ai-split-banner-heading-{{ ai_gen_id }} {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
      margin-bottom: {{ section.settings.heading_margin_bottom_mobile }}px;
    }

    .ai-split-banner-subheading-{{ ai_gen_id }} {
      font-size: {{ section.settings.subheading_font_size_mobile }}px;
      margin-bottom: {{ section.settings.subheading_margin_bottom_mobile }}px;
    }

    .ai-split-banner-description-{{ ai_gen_id }} {
      font-size: {{ section.settings.description_font_size_mobile }}px;
      margin-bottom: {{ section.settings.description_margin_bottom_mobile }}px;
    }

    .ai-split-banner-button-{{ ai_gen_id }} {
      font-size: {{ section.settings.button_font_size_mobile }}px;
      {% if section.settings.button_full_width_mobile %}
        width: 100%;
      {% endif %}
    }

    .ai-split-banner-buttons-{{ ai_gen_id }} {
      gap: {{ section.settings.button_gap_mobile }}px;
      {% if section.settings.button_full_width_mobile %}
        flex-direction: column;
      {% endif %}
    }

    .ai-split-banner-badge-{{ ai_gen_id }} {
      font-size: {{ section.settings.badge_font_size_mobile }}px;
      margin-bottom: {{ section.settings.badge_margin_bottom_mobile }}px;
    }

    .ai-split-banner-content-left-{{ ai_gen_id }} {
      text-align: {{ section.settings.text_align_mobile_left }};
      align-items: {{ section.settings.content_position_vertical_mobile_left }};
    }

    .ai-split-banner-content-right-{{ ai_gen_id }} {
      text-align: {{ section.settings.text_align_mobile_right }};
      align-items: {{ section.settings.content_position_vertical_mobile_right }};
    }

    .ai-split-banner-content-left-{{ ai_gen_id }}.ai-split-banner-align-center-mobile-{{ ai_gen_id }} {
      justify-content: center;
    }

    .ai-split-banner-content-left-{{ ai_gen_id }}.ai-split-banner-align-right-mobile-{{ ai_gen_id }} {
      justify-content: flex-end;
    }

    .ai-split-banner-content-right-{{ ai_gen_id }}.ai-split-banner-align-center-mobile-{{ ai_gen_id }} {
      justify-content: center;
    }

    .ai-split-banner-content-right-{{ ai_gen_id }}.ai-split-banner-align-right-mobile-{{ ai_gen_id }} {
      justify-content: flex-end;
    }
  }
{% endstyle %}

<split-banner-{{ ai_gen_id }} class="ai-split-banner-{{ ai_gen_id }}" {{ section.shopify_attributes }}>
  <div class="ai-split-banner-container-{{ ai_gen_id }}">
    <div class="ai-split-banner-wrapper-{{ ai_gen_id }}">
      
      <div class="ai-split-banner-item-{{ ai_gen_id }}">
        <div class="ai-split-banner-image-wrapper-{{ ai_gen_id }}">
          {% if section.settings.use_separate_mobile_images and section.settings.left_image_mobile %}
            <picture>
              <source media="(max-width: 767px)" srcset="{{ section.settings.left_image_mobile | image_url: width: 800 }}">
              {% if section.settings.left_image %}
                <img
                  src="{{ section.settings.left_image | image_url: width: 1200 }}"
                  alt="{{ section.settings.left_image.alt | escape }}"
                  width="{{ section.settings.left_image.width }}"
                  height="{{ section.settings.left_image.height }}"
                  loading="lazy"
                  class="ai-split-banner-image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-split-banner-image-{{ ai_gen_id }}" style="background-color: #f4f4f4; display: flex; align-items: center; justify-content: center;">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </picture>
          {% elsif section.settings.left_image %}
            <img
              src="{{ section.settings.left_image | image_url: width: 1200 }}"
              alt="{{ section.settings.left_image.alt | escape }}"
              width="{{ section.settings.left_image.width }}"
              height="{{ section.settings.left_image.height }}"
              loading="lazy"
              class="ai-split-banner-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-split-banner-image-{{ ai_gen_id }}" style="background-color: #f4f4f4; display: flex; align-items: center; justify-content: center;">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
          <div class="ai-split-banner-overlay-{{ ai_gen_id }}"></div>
        </div>
        
        <div class="ai-split-banner-content-{{ ai_gen_id }} ai-split-banner-content-left-{{ ai_gen_id }} 
          {% if section.settings.content_position_horizontal_left == 'center' %}ai-split-banner-align-center-{{ ai_gen_id }}{% endif %}
          {% if section.settings.content_position_horizontal_left == 'right' %}ai-split-banner-align-right-{{ ai_gen_id }}{% endif %}
          {% if section.settings.content_position_horizontal_mobile_left == 'center' %}ai-split-banner-align-center-mobile-{{ ai_gen_id }}{% endif %}
          {% if section.settings.content_position_horizontal_mobile_left == 'right' %}ai-split-banner-align-right-mobile-{{ ai_gen_id }}{% endif %}">
          <div class="ai-split-banner-content-inner-{{ ai_gen_id }}">
            {% if section.settings.left_badge != blank %}
              <div class="ai-split-banner-badge-{{ ai_gen_id }}">
                {{ section.settings.left_badge }}
              </div>
            {% endif %}
            
            {% if section.settings.left_heading != blank %}
              <h2 class="ai-split-banner-heading-{{ ai_gen_id }}">
                {{ section.settings.left_heading }}
              </h2>
            {% endif %}
            
            {% if section.settings.left_subheading != blank %}
              <h3 class="ai-split-banner-subheading-{{ ai_gen_id }}">
                {{ section.settings.left_subheading }}
              </h3>
            {% endif %}
            
            {% if section.settings.left_description != blank %}
              <div class="ai-split-banner-description-{{ ai_gen_id }}">
                {{ section.settings.left_description }}
              </div>
            {% endif %}
            
            {% if section.settings.left_button_primary_text != blank or section.settings.left_button_secondary_text != blank %}
              <div class="ai-split-banner-buttons-{{ ai_gen_id }}">
                {% if section.settings.left_button_primary_text != blank %}
                  <a 
                    href="{{ section.settings.left_button_primary_link | default: '#' }}" 
                    class="ai-split-banner-button-{{ ai_gen_id }} ai-split-banner-button-primary-{{ ai_gen_id }}"
                    {% if section.settings.left_button_primary_link == blank %}aria-disabled="true"{% endif %}>
                    {{ section.settings.left_button_primary_text }}
                  </a>
                {% endif %}
                
                {% if section.settings.left_button_secondary_text != blank %}
                  <a 
                    href="{{ section.settings.left_button_secondary_link | default: '#' }}" 
                    class="ai-split-banner-button-{{ ai_gen_id }} ai-split-banner-button-secondary-{{ ai_gen_id }}"
                    {% if section.settings.left_button_secondary_link == blank %}aria-disabled="true"{% endif %}>
                    {{ section.settings.left_button_secondary_text }}
                  </a>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>
      </div>

      <div class="ai-split-banner-item-{{ ai_gen_id }}">
        <div class="ai-split-banner-image-wrapper-{{ ai_gen_id }}">
          {% if section.settings.use_separate_mobile_images and section.settings.right_image_mobile %}
            <picture>
              <source media="(max-width: 767px)" srcset="{{ section.settings.right_image_mobile | image_url: width: 800 }}">
              {% if section.settings.right_image %}
                <img
                  src="{{ section.settings.right_image | image_url: width: 1200 }}"
                  alt="{{ section.settings.right_image.alt | escape }}"
                  width="{{ section.settings.right_image.width }}"
                  height="{{ section.settings.right_image.height }}"
                  loading="lazy"
                  class="ai-split-banner-image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-split-banner-image-{{ ai_gen_id }}" style="background-color: #f4f4f4; display: flex; align-items: center; justify-content: center;">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </picture>
          {% elsif section.settings.right_image %}
            <img
              src="{{ section.settings.right_image | image_url: width: 1200 }}"
              alt="{{ section.settings.right_image.alt | escape }}"
              width="{{ section.settings.right_image.width }}"
              height="{{ section.settings.right_image.height }}"
              loading="lazy"
              class="ai-split-banner-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-split-banner-image-{{ ai_gen_id }}" style="background-color: #f4f4f4; display: flex; align-items: center; justify-content: center;">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
          <div class="ai-split-banner-overlay-{{ ai_gen_id }}"></div>
        </div>
        
        <div class="ai-split-banner-content-{{ ai_gen_id }} ai-split-banner-content-right-{{ ai_gen_id }}
          {% if section.settings.content_position_horizontal_right == 'center' %}ai-split-banner-align-center-{{ ai_gen_id }}{% endif %}
          {% if section.settings.content_position_horizontal_right == 'right' %}ai-split-banner-align-right-{{ ai_gen_id }}{% endif %}
          {% if section.settings.content_position_horizontal_mobile_right == 'center' %}ai-split-banner-align-center-mobile-{{ ai_gen_id }}{% endif %}
          {% if section.settings.content_position_horizontal_mobile_right == 'right' %}ai-split-banner-align-right-mobile-{{ ai_gen_id }}{% endif %}">
          <div class="ai-split-banner-content-inner-{{ ai_gen_id }}">
            {% if section.settings.right_badge != blank %}
              <div class="ai-split-banner-badge-{{ ai_gen_id }}">
                {{ section.settings.right_badge }}
              </div>
            {% endif %}
            
            {% if section.settings.right_heading != blank %}
              <h2 class="ai-split-banner-heading-{{ ai_gen_id }}">
                {{ section.settings.right_heading }}
              </h2>
            {% endif %}
            
            {% if section.settings.right_subheading != blank %}
              <h3 class="ai-split-banner-subheading-{{ ai_gen_id }}">
                {{ section.settings.right_subheading }}
              </h3>
            {% endif %}
            
            {% if section.settings.right_description != blank %}
              <div class="ai-split-banner-description-{{ ai_gen_id }}">
                {{ section.settings.right_description }}
              </div>
            {% endif %}
            
            {% if section.settings.right_button_primary_text != blank or section.settings.right_button_secondary_text != blank %}
              <div class="ai-split-banner-buttons-{{ ai_gen_id }}">
                {% if section.settings.right_button_primary_text != blank %}
                  <a 
                    href="{{ section.settings.right_button_primary_link | default: '#' }}" 
                    class="ai-split-banner-button-{{ ai_gen_id }} ai-split-banner-button-primary-{{ ai_gen_id }}"
                    {% if section.settings.right_button_primary_link == blank %}aria-disabled="true"{% endif %}>
                    {{ section.settings.right_button_primary_text }}
                  </a>
                {% endif %}
                
                {% if section.settings.right_button_secondary_text != blank %}
                  <a 
                    href="{{ section.settings.right_button_secondary_link | default: '#' }}" 
                    class="ai-split-banner-button-{{ ai_gen_id }} ai-split-banner-button-secondary-{{ ai_gen_id }}"
                    {% if section.settings.right_button_secondary_link == blank %}aria-disabled="true"{% endif %}>
                    {{ section.settings.right_button_secondary_text }}
                  </a>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>
      </div>

    </div>
  </div>
</split-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class SplitBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initAccessibility();
      }

      initAccessibility() {
        const buttons = this.querySelectorAll('a[aria-disabled="true"]');
        buttons.forEach(button => {
          button.addEventListener('click', (e) => {
            e.preventDefault();
          });
        });
      }
    }

    customElements.define('split-banner-{{ ai_gen_id }}', SplitBanner{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Split image banner",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {
          "value": "full-width",
          "label": "Full width"
        },
        {
          "value": "boxed",
          "label": "Boxed"
        }
      ],
      "default": "full-width"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "label": "Container max width",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "gap_between_banners",
      "label": "Gap between banners",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "gap_between_banners_mobile",
      "label": "Gap on mobile",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "section_margin_top",
      "label": "Section margin top",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "section_margin_bottom",
      "label": "Section margin bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
