{%- style -%}
  /* ─── FAQ Premium ─── */
  #faq-{{ section.id }} .accordion-item {
    border: none;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    transition: background 0.2s ease;
  }

  #faq-{{ section.id }} .accordion-item:last-child {
    border-bottom: none;
  }

  #faq-{{ section.id }} .accordion-item:hover {
    background: rgba(0, 0, 0, 0.01);
  }

  #faq-{{ section.id }} .accordion-button {
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
    padding: 20px 16px;
    transition: color 0.2s ease, box-shadow 0.2s ease;
    border-radius: 0;
  }

  #faq-{{ section.id }} .accordion-button:not(.collapsed) {
    color: var(--dt-primary-color, #000);
    font-weight: 700;
  }

  #faq-{{ section.id }} .accordion-button:focus {
    box-shadow: none;
    outline: 2px solid var(--dt-primary-color, #000);
    outline-offset: -2px;
  }

  #faq-{{ section.id }} .accordion-button::after {
    width: 20px;
    height: 20px;
    background-size: 16px;
    transition: transform 0.3s ease;
  }

  #faq-{{ section.id }} .accordion-body {
    padding: 0 16px 20px;
    line-height: 1.7;
    color: rgba(0, 0, 0, 0.6);
    font-size: 0.9375rem;
  }

  #faq-{{ section.id }} .accordion-collapse {
    transition: height 0.3s ease;
  }
{%- endstyle -%}

{% render 'section-tokens', settings: section.settings, section_id: section.id %}

<div
  id="faq-{{ section.id }}" 
  class="
    faq 
    {{ section.settings.bg_color }} 
    {{ section.settings.bg_gradient }}
    {{ section.settings.text_color }}
    {{ section.settings.border_top_width | prepend: 'border-top-' }}
    {{ section.settings.border_bottom_width | prepend: 'border-bottom-' }}
    {{ section.settings.border_color }} 
    {{ section.settings.pt | prepend: 'pt-' }} 
    {{ section.settings.pb | prepend: 'pb-' }}
  ">
  <div 
    class="container phantom-animate"
    style="max-width: {{ section.settings.container_max_width }}px">
    <div class="row align-items-center">
      <div class="col-desktop-8">
        {% render 'section-header' %}
      </div>
      <div class="col-desktop-10">
        <div data-skeleton-wrapper>
          <div data-skeleton-content>
            <div 
              id="faq-accordion-{{ section.id }}" 
              class="accordion"
              data-accordion>
              {% for block in section.blocks %}
                <div
                  class="accordion-item phantom-accordion-item"
                  data-index="{{ forloop.index0 }}"
                  {{ block.shopify_attributes }}>
                  {% render 'block-positioning', settings: block.settings, block_id: block.id %}
                  <h3 
                    id="faq-accordion-{{ section.id }}-heading-{{ forloop.index }}" 
                    class="accordion-header">
                    <button
                      class="accordion-button phantom-accordion-trigger {% unless section.settings.open_first_item == true and forloop.first %}collapsed{% endunless %}" 
                      type="button" 
                      data-faq-trigger
                      aria-expanded="{% if section.settings.open_first_item == true and forloop.first %}true{% else %}false{% endif %}" 
                      aria-controls="faq-accordion-{{ section.id }}-collapse-{{ forloop.index }}">
                      {{ block.settings.title | escape }}
                    </button>
                  </h3>
                  <div 
                    id="faq-accordion-{{ section.id }}-collapse-{{ forloop.index }}" 
                    class="accordion-collapse {% if section.settings.open_first_item == true and forloop.first %}show{% endif %}" 
                    aria-labelledby="faq-accordion-{{ section.id }}-heading-{{ forloop.index }}">
                    <div class="accordion-body rte">
                      {{ block.settings.description }}
                    </div>
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>
          <div data-skeleton-placeholder>
            {% for i in (1..4) %}
              <div class="accordion-item" style="border: 1px solid rgba(0,0,0,0.06); padding: 20px;">
                <span class="skeleton skeleton-heading" style="width: 60%; height: 1.2em; margin-bottom: 0;"></span>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    'use strict';

    function initFaqAccordion(container) {
      var accordion = container.querySelector('[data-accordion]');
      if (!accordion) return;

      var triggers = accordion.querySelectorAll('[data-faq-trigger]');

      function closeAll() {
        triggers.forEach(function(btn) {
          var targetId = btn.getAttribute('aria-controls');
          var target = document.getElementById(targetId);
          if (target) {
            target.classList.remove('show');
            btn.classList.add('collapsed');
            btn.setAttribute('aria-expanded', 'false');
          }
        });
      }

      triggers.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var targetId = this.getAttribute('aria-controls');
          var target = document.getElementById(targetId);
          if (!target) return;

          var isOpen = target.classList.contains('show');

          // Accordion behavior: close all others
          closeAll();

          // Toggle current
          if (!isOpen) {
            target.classList.add('show');
            this.classList.remove('collapsed');
            this.setAttribute('aria-expanded', 'true');
          }
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        initFaqAccordion(document.getElementById('faq-{{ section.id }}'));
      });
    } else {
      initFaqAccordion(document.getElementById('faq-{{ section.id }}'));
    }

    {% if request.design_mode %}
      document.addEventListener('shopify:block:select', function(event) {
        var sectionEl = document.getElementById('faq-{{ section.id }}');
        if (!sectionEl) return;
        var index = Number(event.target.dataset.index);
        var accordion = sectionEl.querySelector('[data-accordion]');
        if (!accordion) return;
        var items = accordion.querySelectorAll('.accordion-item');
        var targetItem = items[index];
        if (targetItem) {
          var btn = targetItem.querySelector('[data-faq-trigger]');
          if (btn) btn.click();
        }
      });
    {% endif %}
  })();
</script>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
    {% for block in section.blocks %}
      {
        "@type": "Question",
        "name": {{ block.settings.title | json }},
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ block.settings.description | json }}
        }
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
    ]
  }
</script>

