<div
  class="impulse-recently-viewed"
  id="impulse-recently-viewed--{{ section.id }}"
  data-section-type="impulse-recently-viewed"
  data-product-count="{{ section.settings.product_count }}"
  data-currency="{{ localization.country.currency.iso_code }}"
>
  <div class="page-width">
    <header class="impulse-recently-viewed__header section-header text-center">
      {%- if section.settings.heading != blank -%}
        <h2 class="section-header__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </header>

    <div class="impulse-recently-viewed__loading" aria-busy="true">
      <div class="impulse-recently-viewed__skeleton-grid">
        {%- for i in (1..section.settings.product_count) -%}
          <div class="impulse-recently-viewed__skeleton-card">
            <div class="impulse-recently-viewed__skeleton-image pulse"></div>
            <div class="impulse-recently-viewed__skeleton-text pulse"></div>
            <div class="impulse-recently-viewed__skeleton-text impulse-recently-viewed__skeleton-text--short pulse"></div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <div class="impulse-recently-viewed__grid"></div>
  </div>
</div>

{%- style -%}
  #impulse-recently-viewed--{{ section.id }} {
    padding-top: 40px;
    padding-bottom: 40px;
  }

  #impulse-recently-viewed--{{ section.id }} .impulse-recently-viewed__header {
    margin-bottom: 24px;
  }

  #impulse-recently-viewed--{{ section.id }} .section-header__title {
    font-size: 1.5em;
    font-weight: 700;
  }

  #impulse-recently-viewed--{{ section.id }} .impulse-recently-viewed__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.product_count | at_most: 4 }}, 1fr);
    gap: 16px;
  }

  @media screen and (max-width: 768px) {
    #impulse-recently-viewed--{{ section.id }} .impulse-recently-viewed__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
  }

  @media screen and (max-width: 480px) {
    #impulse-recently-viewed--{{ section.id }} .impulse-recently-viewed__grid {
      grid-template-columns: repeat({{ section.settings.product_count | at_most: 2 }}, 1fr);
    }
  }

  /* Product card */
  #impulse-recently-viewed--{{ section.id }} .impulse-recently-viewed__card {
    display: block;
    text-decoration: none;
    color: inherit;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 4px;
    overflow: hidden;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  #impulse-recently-viewed--{{ section.id }} .impulse-recently-viewed__card:hover {
    box-shadow: 0 2px 12px rgba(0,0,0,0.1);
    transform: translateY(-2px);
  }

  #impulse-recently-viewed--{{ section.id }} .impulse-recently-viewed__image {
    position: relative;
    padding-bottom: 100%;
    background: #f9f9f9;
    overflow: hidden;
  }

  #impulse-recently-viewed--{{ section.id }} .impulse-recently-viewed__image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #impulse-recently-viewed--{{ section.id }} .impulse-recently-viewed__image--placeholder svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  #impulse-recently-viewed--{{ section.id }} .impulse-recently-viewed__info {
    padding: 12px;
  }

  #impulse-recently-viewed--{{ section.id }} .impulse-recently-viewed__title {
    margin: 0 0 4px;
    font-size: 0.9em;
    font-weight: 600;
    line-height: 1.3;
  }

  #impulse-recently-viewed--{{ section.id }} .impulse-recently-viewed__price {
    font-size: 0.85em;
    opacity: 0.8;
  }

  /* Skeleton loader */
  #impulse-recently-viewed--{{ section.id }} .impulse-recently-viewed__loading {
    width: 100%;
  }

  #impulse-recently-viewed--{{ section.id }} .impulse-recently-viewed__skeleton-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.product_count | at_most: 4 }}, 1fr);
    gap: 16px;
  }

  @media screen and (max-width: 768px) {
    #impulse-recently-viewed--{{ section.id }} .impulse-recently-viewed__skeleton-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  #impulse-recently-viewed--{{ section.id }} .impulse-recently-viewed__skeleton-card {
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 4px;
    overflow: hidden;
  }

  #impulse-recently-viewed--{{ section.id }} .impulse-recently-viewed__skeleton-image {
    padding-bottom: 100%;
    background: #f0f0f0;
  }

  #impulse-recently-viewed--{{ section.id }} .impulse-recently-viewed__skeleton-text {
    height: 14px;
    margin: 12px 12px 0;
    background: #f0f0f0;
    border-radius: 4px;
  }

  #impulse-recently-viewed--{{ section.id }} .impulse-recently-viewed__skeleton-text--short {
    width: 60%;
    margin-bottom: 12px;
  }

  @keyframes pulse {
    0% { opacity: 1; }
    50% { opacity: 0.4; }
    100% { opacity: 1; }
  }

  #impulse-recently-viewed--{{ section.id }} .pulse {
    animation: pulse 1.5s ease-in-out infinite;
  }
{%- endstyle -%}

<script src="{{ 'impulse-recently-viewed.js' | asset_url }}" type="module" defer></script>

{% schema %}
{
  "name": "Recently viewed",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recently viewed"
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Number of products",
      "default": 4,
      "min": 2,
      "max": 8,
      "step": 1
    }
  ],
  "presets": [
    {
      "name": "Recently viewed",
      "category": "Products"
    }
  ],
  "disabled_on": {
    "groups": ["footer", "header", "custom.popups"]
  }
}
{% endschema %}
