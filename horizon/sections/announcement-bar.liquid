{% render 'section-tokens', settings: section.settings, section_id: section.id %}

<section 
  id="announcement-bar-{{ section.id }}" 
  class="
    announcement-bar 
    {{ section.settings.bg_color }} 
    {{ section.settings.bg_gradient }}
    {{ section.settings.text_color }}
    {{ section.settings.border_top_width | prepend: 'border-top-' }}
    {{ section.settings.border_bottom_width | prepend: 'border-bottom-' }}
    {{ section.settings.border_color }} 
    {{ section.settings.font_size }} 
    {{ section.settings.font_size_desktop }} 
    {{ section.settings.text_transform }} 
    {{ section.settings.letter_spacing | prepend: 'ls-' }} 
   px-mobile-3">
  <div class="container">
    <div 
      id="carousel-{{ section.id }}" 
      class="carousel slide" 
      data-interval="{{ section.settings.carousel_autoplay | times: 1000 }}"
      data-autoplay="{{ section.settings.carousel_autoplay }}"
      aria-label="{{ 'general.accessibility.announcements' | t }}"
      style="max-width: {{ section.settings.container_max_width }}px;">
      <div class="carousel-inner">
        {% for block in section.blocks %}
          <div 
            class="
              carousel-item 
              {{ section.settings.pt | prepend: 'pt-' }} 
              {{ section.settings.pb | prepend: 'pb-' }}
              {% if forloop.first %}active{% endif %}
            " 
            data-index="{{ forloop.index0 }}" 
            {{ block.shopify_attributes }}>
            {% render 'block-positioning', settings: block.settings, block_id: block.id %}
            <div class="description rte lh-sm">
              {{ block.settings.announcement }}
            </div>
          </div>
        {% endfor %}
      </div>
      {% if section.blocks.size > 1 %}
        <button 
          class="carousel-control carousel-control-prev" 
          type="button" 
          data-slide="prev"
          aria-label="{{ 'general.accessibility.previous' | t }}">
          {% render 'svg-icons', icon: 'chevron-left', size: 22 %}
        </button>
        <button 
          class="carousel-control carousel-control-next" 
          type="button" 
          data-slide="next"
          aria-label="{{ 'general.accessibility.next' | t }}">
          {% render 'svg-icons', icon: 'chevron-right', size: 22 %}
        </button>
      {% endif %}
    </div>
  </div>
</section>

<script>
  (function() {
    'use strict';

    function initAnnouncementCarousel(container) {
      var carouselEl = container.querySelector('#carousel-{{ section.id }}');
      if (!carouselEl) return;

      var inner = carouselEl.querySelector('.carousel-inner');
      var slides = carouselEl.querySelectorAll('.carousel-item');
      var prevBtn = carouselEl.querySelector('[data-slide="prev"]');
      var nextBtn = carouselEl.querySelector('[data-slide="next"]');
      var currentIndex = 0;
      var autoplayMs = parseInt(carouselEl.dataset.interval) || 5000;
      var autoplayEnabled = parseInt(carouselEl.dataset.autoplay) > 0;
      var timer = null;

      function goTo(index) {
        if (index < 0) index = slides.length - 1;
        if (index >= slides.length) index = 0;

        slides.forEach(function(s) { s.classList.remove('active'); });

        currentIndex = index;
        slides[index].classList.add('active');

        resetAutoplay();
      }

      function next() { goTo(currentIndex + 1); }
      function prev() { goTo(currentIndex - 1); }

      function startAutoplay() {
        if (!autoplayEnabled || autoplayMs <= 0) return;
        stopAutoplay();
        timer = setInterval(next, autoplayMs);
      }

      function stopAutoplay() {
        if (timer) { clearInterval(timer); timer = null; }
      }

      function resetAutoplay() {
        if (autoplayEnabled) {
          stopAutoplay();
          startAutoplay();
        }
      }

      if (prevBtn) prevBtn.addEventListener('click', function(e) { e.preventDefault(); prev(); });
      if (nextBtn) nextBtn.addEventListener('click', function(e) { e.preventDefault(); next(); });

      carouselEl.addEventListener('mouseenter', stopAutoplay);
      carouselEl.addEventListener('mouseleave', startAutoplay);

      // Mobile swipe support
      if (slides.length > 1 && window.PhantomTouch && window.PhantomTouch.SwipeDetector) {
        var swipe = new window.PhantomTouch.SwipeDetector(carouselEl, {
          onSwipeLeft:  next,
          onSwipeRight: prev,
          threshold: 40,
        });
      }

      startAutoplay();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        initAnnouncementCarousel(document.getElementById('announcement-bar-{{ section.id }}'));
      });
    } else {
      initAnnouncementCarousel(document.getElementById('announcement-bar-{{ section.id }}'));
    }

    {% if request.design_mode %}
      document.addEventListener('shopify:block:select', function(event) {
        var sectionEl = document.getElementById('announcement-bar-{{ section.id }}');
        if (!sectionEl) return;
        var carousel = sectionEl.querySelector('#carousel-{{ section.id }}');
        if (!carousel) return;
        var targetSlide = sectionEl.querySelector('[data-index="' + event.target.dataset.index + '"]');
        if (targetSlide) {
          var allSlides = carousel.querySelectorAll('.carousel-item');
          allSlides.forEach(function(s) { s.classList.remove('active'); });
          targetSlide.classList.add('active');
        }
      });
    {% endif %}
  })();
</script>

