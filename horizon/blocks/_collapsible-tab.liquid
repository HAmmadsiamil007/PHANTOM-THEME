{%- assign block_settings = block.settings -%}

{%- capture tab_content -%}
  {%- if block_settings.content != blank -%}
    {{ block_settings.content }}
  {%- elsif block_settings.page != blank -%}
    {{ block_settings.page.content }}
  {%- endif -%}
{%- endcapture -%}

{% stylesheet %}
  .collapsible-tab {
    width: 100%;
  }

  .collapsible-tab + .collapsible-tab {
    border-block-start: var(--style-border-width) solid var(--color-border, rgb(var(--color-foreground-rgb) / 0.15));
  }

  .collapsible-tab__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--gap-sm);
    cursor: pointer;
    min-height: var(--minimum-touch-target);
  }

  .collapsible-tab__title {
    flex: 1;
    font-size: calc(var(--font-body-scale) * 1rem);
    font-weight: var(--font-body-weight-medium, 500);
  }

  .collapsible-tab__content {
    margin-block-start: calc(var(--gap-sm) / 2);
  }
{% endstylesheet %}

{%- if block_settings.title != blank and tab_content != blank -%}
  {% capture tab_children %}
    <details
      class="details collapsible-tab"
      data-testid="collapsible-tab-details"
      {% if block_settings.open_by_default %}
        open
      {% endif %}
      {{ block.shopify_attributes }}
    >
      <summary class="details__header collapsible-tab__header">
        <span class="collapsible-tab__title">{{ block_settings.title }}</span>
        <span class="svg-wrapper icon-caret icon-animated">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
        <span class="svg-wrapper icon-plus">
          {{- 'icon-plus.svg' | inline_asset_content -}}
        </span>
      </summary>

      <div class="details-content collapsible-tab__content rte">
        {{ tab_content }}
      </div>
    </details>
  {% endcapture %}

  {% render 'accordion-custom-component',
    children: tab_children,
    open_by_default_on_desktop: block_settings.open_by_default,
    open_by_default_on_mobile: block_settings.open_by_default
  %}
{%- endif -%}

{% schema %}
{
  "name": "t:names.collapsible_tab",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:settings.heading",
      "default": "Collapsible tab"
    },
    {
      "type": "checkbox",
      "id": "open_by_default",
      "label": "t:settings.open_by_default",
      "default": false
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "t:settings.content",
      "default": "<p>Use collapsible tabs for more detailed information that will help customers make a purchasing decision.</p><p>Ex: Shipping and return policies, size guides, and other common questions.</p>"
    },
    {
      "type": "page",
      "id": "page",
      "label": "t:settings.page"
    }
  ],
  "presets": [
    {
      "name": "t:names.collapsible_tab",
      "category": "t:categories.product",
      "settings": {
        "title": "Shipping information",
        "content": "<p>Provide shipping and delivery information here.</p>"
      }
    }
  ]
}
{% endschema %}
